<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#2D4A30">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <!-- Canonical & OG -->
  <link rel="canonical" href="{{ canonical_url }}">
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ page_title | escape }}">
  <meta property="og:type" content="website">
  {% if page_image %}
    <meta property="og:image" content="https:{{ page_image | img_url: '1200x630' }}">
  {% endif %}

  <!-- Shopify required -->
  {{ content_for_header }}

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">

  <!-- Theme CSS -->
  {{ 'solmara.css' | asset_url | stylesheet_tag }}

  <!-- Favicon -->
  {% if settings.favicon != blank %}
    <link rel="shortcut icon" href="{{ settings.favicon | img_url: '32x32' }}" type="image/png">
  {% endif %}
</head>

<body class="template-{{ template.name }}">

  <!-- ═══════════════════════════════ ANNOUNCEMENT BAR ═══════════════════════════════ -->
  {%- if settings.announcement_text != blank -%}
  <div class="top-bar">
    <span>🌿 {{ settings.announcement_text }}</span>
    {%- if settings.announcement_text_2 != blank -%}
      <span class="dot"></span>
      <span>✦ {{ settings.announcement_text_2 }}</span>
    {%- endif -%}
    {%- if settings.announcement_text_3 != blank -%}
      <span class="dot"></span>
      <span>🔬 {{ settings.announcement_text_3 }}</span>
    {%- endif -%}
  </div>
  {%- endif -%}

  <!-- ═══════════════════════════════ HEADER ═══════════════════════════════ -->
  <header id="site-header">
    <a class="logo" href="{{ routes.root_url }}">
      {{ shop.name }} <span class="logo-dot"></span>
    </a>

    <nav aria-label="Main navigation">
      {%- for link in linklists[settings.main_menu].links -%}
        <a href="{{ link.url }}"
           {% if link.active %}aria-current="page"{% endif %}>
          {{ link.title }}
        </a>
      {%- endfor -%}
    </nav>

    <div class="header-right">
      <!-- Search -->
      <button class="icon-btn" onclick="document.querySelector('.search-drawer').classList.toggle('open')" aria-label="Search">
        🔍
      </button>

      <!-- Account -->
      <a class="icon-btn" href="{{ routes.account_url }}" aria-label="Account">👤</a>

      <!-- Cart -->
      <button class="cart-pill" onclick="openCart()" aria-label="Open cart">
        🛒 Bag
        <span class="cart-badge" id="cartBadge">{{ cart.item_count }}</span>
      </button>
    </div>
  </header>

  <!-- ═══════════════════════════════ MAIN CONTENT ═══════════════════════════════ -->
  <main id="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  <!-- ═══════════════════════════════ FOOTER ═══════════════════════════════ -->
  <footer>
    <div class="footer-top">
      <div>
        <div class="footer-logo">
          <a href="{{ routes.root_url }}">{{ shop.name }} <span class="footer-logo-dot"></span></a>
        </div>
        <p class="footer-tagline">{{ settings.footer_tagline }}</p>
        <div class="footer-certs">
          {%- if settings.cert_1 != blank -%}<span class="cert-badge">{{ settings.cert_1 }}</span>{%- endif -%}
          {%- if settings.cert_2 != blank -%}<span class="cert-badge">{{ settings.cert_2 }}</span>{%- endif -%}
          {%- if settings.cert_3 != blank -%}<span class="cert-badge">{{ settings.cert_3 }}</span>{%- endif -%}
          {%- if settings.cert_4 != blank -%}<span class="cert-badge">{{ settings.cert_4 }}</span>{%- endif -%}
        </div>
      </div>

      {%- for i in (1..3) -%}
        {%- assign menu_key = 'footer_menu_' | append: i -%}
        {%- assign title_key = 'footer_menu_title_' | append: i -%}
        {%- if linklists[settings[menu_key]].links.size > 0 -%}
        <div class="footer-col">
          <h5>{{ settings[title_key] }}</h5>
          <ul class="footer-links">
            {%- for link in linklists[settings[menu_key]].links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>

      <div class="footer-socials">
        {%- if settings.social_instagram != blank -%}
          <a class="social-btn" href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">IG</a>
        {%- endif -%}
        {%- if settings.social_tiktok != blank -%}
          <a class="social-btn" href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">TK</a>
        {%- endif -%}
        {%- if settings.social_pinterest != blank -%}
          <a class="social-btn" href="{{ settings.social_pinterest }}" target="_blank" rel="noopener" aria-label="Pinterest">PI</a>
        {%- endif -%}
        {%- if settings.social_youtube != blank -%}
          <a class="social-btn" href="{{ settings.social_youtube }}" target="_blank" rel="noopener" aria-label="YouTube">YT</a>
        {%- endif -%}
      </div>

      <div class="footer-pay">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'pay-icon' }}
        {%- endfor -%}
      </div>
    </div>
  </footer>

  <!-- ═══════════════════════════════ CART DRAWER ═══════════════════════════════ -->
  <div class="overlay" id="overlay" onclick="closeCart()"></div>
  <div class="cart-drawer" id="cartDrawer" aria-modal="true" role="dialog" aria-label="Shopping cart">
    <div class="cd-header">
      <h2 class="cd-title">Your Bag</h2>
      <button class="cd-close" onclick="closeCart()" aria-label="Close cart">✕</button>
    </div>

    <div class="cd-items" id="cdItems">
      <!-- Populated by solmara.js via Shopify AJAX Cart API -->
      <div class="cd-empty" id="cdEmpty">
        <div class="cd-empty-icon">🌿</div>
        <div class="cd-empty-text">Your bag is empty</div>
        <div class="cd-empty-sub">Add something good for you</div>
      </div>
    </div>

    <div class="cd-footer" id="cdFooter" style="display:none">
      <div class="cd-subtotal">
        <span>Subtotal</span>
        <strong id="cdTotal">{{ cart.total_price | money }}</strong>
      </div>
      <p class="cd-free-ship" id="cdShipMsg"></p>
      <a class="cd-checkout" href="{{ routes.checkout_url }}">Checkout Securely</a>
      <button class="cd-continue" onclick="closeCart()">Continue Shopping</button>
    </div>
  </div>

  <!-- ═══════════════════════════════ SEARCH DRAWER ═══════════════════════════════ -->
  <div class="search-drawer">
    <div class="search-inner">
      <form action="{{ routes.search_url }}" method="get" role="search">
        <input type="hidden" name="type" value="product">
        <input class="search-input" type="search" name="q" placeholder="Search products..." autocomplete="off" aria-label="Search">
        <button type="submit" class="btn-fill">Search</button>
      </form>
      <button class="search-close" onclick="document.querySelector('.search-drawer').classList.remove('open')">✕</button>
    </div>
  </div>

  <!-- ═══════════════════════════════ TOAST ═══════════════════════════════ -->
  <div class="toast" id="toast" aria-live="polite"></div>

  <!-- Theme JS (deferred for performance) -->
  <script src="{{ 'solmara.js' | asset_url }}" defer></script>

</body>
</html>
