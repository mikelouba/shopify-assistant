<section class="related-products-section">
  <p class="section-eyebrow" style="text-align:center">✦ Complete Your Ritual</p>
  <h2 class="section-title">{{ section.settings.heading }}</h2>

  <div class="products-grid related-grid">
    {%- assign related = recommendations.products -%}
    {%- if related.size > 0 -%}
      {%- for product in related limit: section.settings.products_to_show -%}
        {%- render 'product-card', product: product -%}
      {%- endfor -%}
    {%- else -%}
      {%- comment -%}Fallback: show products from same collection{%- endcomment -%}
      {%- for c in product.collections limit: 1 -%}
        {%- for p in c.products limit: section.settings.products_to_show -%}
          {%- unless p.id == product.id -%}
            {%- render 'product-card', product: p -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Related Products",
  "tag": "div",
  "settings": [
    { "type": "text",  "id": "heading",          "label": "Heading",          "default": "You May Also Like" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 6, "step": 1, "default": 4 }
  ],
  "presets": [{ "name": "Related Products" }]
}
{% endschema %}
