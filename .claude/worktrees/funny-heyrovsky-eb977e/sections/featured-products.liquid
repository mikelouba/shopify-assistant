{%- liquid
  assign collection = collections[section.settings.collection]
  assign products_to_show = section.settings.products_to_show | default: 8
-%}

<section class="products-section" id="products">
  <div class="section-header-row">
    <div>
      <p class="section-eyebrow" style="text-align:left">{{ section.settings.eyebrow }}</p>
      <h2 class="section-title" style="text-align:left;margin-bottom:0">{{ section.settings.heading }}</h2>
    </div>
    <a class="view-all-link" href="{{ section.settings.view_all_url | default: routes.collections_url }}">View All →</a>
  </div>

  <div class="products-grid">
    {%- if collection != blank and collection.products.size > 0 -%}
      {%- for product in collection.products limit: products_to_show -%}
        {%- render 'product-card', product: product -%}
      {%- endfor -%}
    {%- else -%}
      {%- comment -%} Fallback: show placeholder cards in the theme editor {%- endcomment -%}
      {%- for i in (1..8) -%}
        <div class="product-card">
          <div class="p-img-wrap">
            <div class="p-img-bg" style="background: var(--sand)">
              <span class="p-icon">🌿</span>
              <span>Your Product</span>
            </div>
          </div>
          <div class="p-info">
            <p class="p-cat">Category</p>
            <p class="p-name">Product Name</p>
            <div class="p-price-row"><span class="p-price">$00.00</span></div>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "tag": "div",
  "settings": [
    { "type": "text",       "id": "eyebrow",         "label": "Eyebrow text",   "default": "✦ Most Loved" },
    { "type": "text",       "id": "heading",          "label": "Section heading","default": "Our Bestsellers" },
    { "type": "collection", "id": "collection",       "label": "Collection to display" },
    { "type": "range",      "id": "products_to_show", "label": "Products to show", "min": 4, "max": 12, "step": 4, "default": 8 },
    { "type": "url",        "id": "view_all_url",     "label": "View all link"  }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
