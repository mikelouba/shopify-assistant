<div class="blog-page">
  <div class="page-header centered">
    <p class="section-eyebrow">✦ The Solmara Journal</p>
    <h1 class="page-title">Wellness <em>Insights</em></h1>
    <p class="page-subtitle">Science, nature, and the art of feeling well.</p>
  </div>

  <!-- Tag filters -->
  {%- if blog.all_tags.size > 0 -%}
    <div class="blog-tags">
      <a class="blog-tag {% unless current_tags %}active{% endunless %}" href="{{ blog.url }}">All</a>
      {%- for tag in blog.all_tags -%}
        <a class="blog-tag {% if current_tags contains tag %}active{% endif %}"
           href="{{ blog.url }}/tagged/{{ tag | handle }}">{{ tag }}</a>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- paginate blog.articles by section.settings.posts_per_page -%}
    <div class="blog-grid">
      {%- for article in blog.articles -%}
        <article class="blog-card">
          <a href="{{ article.url }}" class="blog-card-img-link">
            {%- if article.image -%}
              {{ article.image | image_url: width: 700 | image_tag:
                  alt: article.image.alt | default: article.title,
                  loading: 'lazy',
                  class: 'blog-card-img',
                  widths: '400, 600, 700',
                  sizes: '(max-width:768px) 100vw, 33vw' }}
            {%- else -%}
              <div class="blog-card-img-placeholder">🌿</div>
            {%- endif -%}
          </a>
          <div class="blog-card-body">
            {%- if article.tags.size > 0 -%}
              <span class="blog-card-tag">{{ article.tags.first }}</span>
            {%- endif -%}
            <h2 class="blog-card-title"><a href="{{ article.url }}">{{ article.title }}</a></h2>
            <p class="blog-card-excerpt">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
            <div class="blog-card-meta">
              <span class="blog-card-author">By {{ article.author }}</span>
              <span class="blog-card-date">{{ article.published_at | date: '%b %d, %Y' }}</span>
            </div>
            <a href="{{ article.url }}" class="blog-card-read">Read More →</a>
          </div>
        </article>
      {%- endfor -%}
    </div>

    {%- render 'pagination', paginate: paginate -%}
  {%- endpaginate -%}
</div>

{% schema %}
{
  "name": "Blog",
  "tag": "div",
  "settings": [
    { "type": "range", "id": "posts_per_page", "label": "Posts per page", "min": 3, "max": 12, "step": 3, "default": 9 }
  ],
  "presets": [{"name":"Blog"}]
}
{% endschema %}
