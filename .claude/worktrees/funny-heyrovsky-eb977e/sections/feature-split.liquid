{% comment %}─── FEATURE SPLIT ───{% endcomment %}
<section class="feature-section">
  <div class="feature-visual">
    {%- if section.settings.feature_image != blank -%}
      {{ section.settings.feature_image | image_url: width: 800 | image_tag:
          alt: section.settings.heading,
          loading: 'lazy',
          class: 'feature-img-photo' }}
    {%- else -%}
      <div class="feature-circles">
        <div class="fc-outer">
          <div class="fc-inner">
            <span class="fc-emoji">🌱</span>
            <span class="fc-text">Pure Source</span>
          </div>
        </div>
        <div class="fc-dot"></div>
        <div class="fc-dot2"></div>
      </div>
    {%- endif -%}
  </div>

  <div class="feature-content">
    <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="feature-title">{{ section.settings.heading | replace: "nature's", "<em>nature's</em>" }}</h2>
    <p class="feature-body">{{ section.settings.body }}</p>

    <div class="feature-pillars">
      {%- for i in (1..3) -%}
        {%- assign icon_key  = 'pillar_' | append: i | append: '_icon' -%}
        {%- assign title_key = 'pillar_' | append: i | append: '_title' -%}
        {%- assign body_key  = 'pillar_' | append: i | append: '_body' -%}
        {%- if section.settings[title_key] != blank -%}
          <div class="pillar">
            <span class="pillar-icon">{{ section.settings[icon_key] }}</span>
            <div class="pillar-text">
              <h4>{{ section.settings[title_key] }}</h4>
              <p>{{ section.settings[body_key] }}</p>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <a class="btn-fill" href="{{ section.settings.btn_url }}">{{ section.settings.btn_label }}</a>
  </div>
</section>

{% schema %}
{
  "name": "Feature Split",
  "tag": "div",
  "settings": [
    { "type": "image_picker", "id": "feature_image", "label": "Left image (optional)" },
    { "type": "text",     "id": "eyebrow",       "label": "Eyebrow",  "default": "✦ The Solmara Difference" },
    { "type": "text",     "id": "heading",        "label": "Heading",  "default": "Science meets nature's intelligence" },
    { "type": "textarea", "id": "body",           "label": "Body text" },
    { "type": "header",   "content": "Pillar 1" },
    { "type": "text",     "id": "pillar_1_icon",  "label": "Icon",     "default": "🔬" },
    { "type": "text",     "id": "pillar_1_title", "label": "Title",    "default": "Clinically Validated" },
    { "type": "textarea", "id": "pillar_1_body",  "label": "Body" },
    { "type": "header",   "content": "Pillar 2" },
    { "type": "text",     "id": "pillar_2_icon",  "label": "Icon",     "default": "🌿" },
    { "type": "text",     "id": "pillar_2_title", "label": "Title",    "default": "Certified Organic Sourcing" },
    { "type": "textarea", "id": "pillar_2_body",  "label": "Body" },
    { "type": "header",   "content": "Pillar 3" },
    { "type": "text",     "id": "pillar_3_icon",  "label": "Icon",     "default": "♻️" },
    { "type": "text",     "id": "pillar_3_title", "label": "Title",    "default": "Zero-Plastic Packaging" },
    { "type": "textarea", "id": "pillar_3_body",  "label": "Body" },
    { "type": "header",   "content": "Button" },
    { "type": "text",     "id": "btn_label",      "label": "Button text", "default": "Our Standards →" },
    { "type": "url",      "id": "btn_url",        "label": "Button link" }
  ],
  "presets": [{ "name": "Feature Split" }]
}
{% endschema %}
