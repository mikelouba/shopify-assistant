<div class="collection-banner">
  {%- if collection.image -%}
    <div class="col-banner-img">
      {{ collection.image | image_url: width: 1400 | image_tag:
          alt: collection.title,
          loading: 'eager',
          class: 'col-banner-photo',
          widths: '800, 1000, 1400',
          sizes: '100vw' }}
      <div class="col-banner-overlay"></div>
    </div>
  {%- endif -%}
  <div class="col-banner-content {% unless collection.image %}col-banner-no-img{% endunless %}">
    {%- render 'breadcrumbs' -%}
    <h1 class="col-banner-title">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p class="col-banner-desc">{{ collection.description }}</p>
    {%- endif -%}
    <p class="col-banner-count">{{ collection.products_count }} products</p>
  </div>
</div>

{% schema %}
{
  "name": "Collection Banner",
  "tag": "div",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show collection description",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count",
      "default": true
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 40,
      "info": "Darkens the banner image so text stays readable"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    }
  ],
  "presets": [{ "name": "Collection Banner" }]
}
{% endschema %}
