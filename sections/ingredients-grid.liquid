{%- liquid
  assign bg_color = section.settings.bg_color | default: '#F8F5F0'
  assign cols     = section.settings.cols     | default: '4'
  assign pad      = section.settings.section_padding | default: 60
-%}

<section class="ingredients-section"
  style="background-color: {{ bg_color }}; padding-top: {{ pad }}px; padding-bottom: {{ pad }}px;">
  <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
  <h2 class="section-title">{{ section.settings.heading | replace: 'powerful', '<em>powerful</em>' }}</h2>

  <div class="ing-grid" style="grid-template-columns: repeat({{ cols }}, 1fr);">
    {%- for block in section.blocks -%}
      <div class="ing-card" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <div class="ing-image">
            {{ block.settings.image | image_url: width: 200 | image_tag:
                alt: block.settings.name,
                loading: 'lazy',
                class: 'ing-img' }}
          </div>
        {%- else -%}
          <div class="ing-emoji">{{ block.settings.emoji }}</div>
        {%- endif -%}
        <div class="ing-name">{{ block.settings.name }}</div>
        <div class="ing-desc">{{ block.settings.desc }}</div>
        {%- if block.settings.link != blank -%}
          <a class="ing-link" href="{{ block.settings.link }}">Learn more →</a>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Ingredients Grid",
  "tag": "div",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text",   "id": "eyebrow", "label": "Eyebrow", "default": "✦ Hero Ingredients" },
    { "type": "text",   "id": "heading", "label": "Heading", "default": "Nature's most powerful botanicals" },
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "cols",
      "label": "Columns",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "4",
      "info": "Collapses to 2 columns on mobile."
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 20, "max": 100, "step": 10, "unit": "px",
      "default": 60
    },
    { "type": "header", "content": "Style" },
    { "type": "color",  "id": "bg_color", "label": "Background colour", "default": "#F8F5F0" }
  ],
  "blocks": [{
    "type": "ingredient",
    "name": "Ingredient",
    "settings": [
      { "type": "text",         "id": "emoji", "label": "Emoji (shown if no image)", "default": "🌿" },
      { "type": "image_picker", "id": "image", "label": "Ingredient image (optional)" },
      { "type": "text",         "id": "name",  "label": "Name",                      "default": "Ashwagandha" },
      { "type": "textarea",     "id": "desc",  "label": "Description" },
      { "type": "url",          "id": "link",  "label": "Learn more link (optional)" }
    ]
  }],
  "max_blocks": 8,
  "presets": [{ "name": "Ingredients Grid" }]
}
{% endschema %}
