{%- liquid
  assign show_trust    = section.settings.show_trust_badges   | default: true
  assign show_floating = section.settings.show_floating_cards | default: true
  assign visual_bg     = section.settings.visual_bg           | default: '#F0EBE3'
  assign review_count  = section.settings.stat_review_count   | default: '12,400+'
  assign month_label   = section.settings.stat_month_label    | default: 'This Month'
  assign orders_label  = section.settings.stat_orders_label   | default: 'orders shipped worldwide 🌍'
-%}

<section class="hero">
  <div class="hero-content">
    <div class="hero-eyebrow">
      <span class="leaf-icon">🌿</span>
      {{ section.settings.eyebrow }}
    </div>

    <h1 class="hero-title">
      {{ section.settings.heading | replace: "nature's", "<em>nature's</em>" }}
    </h1>

    <p class="hero-sub">{{ section.settings.subheading }}</p>

    <div class="hero-btns">
      <a class="btn-fill" href="{{ section.settings.btn_primary_url }}">
        {{ section.settings.btn_primary_label }}
      </a>
      <a class="btn-outline" href="{{ section.settings.btn_secondary_url }}">
        {{ section.settings.btn_secondary_label }}
      </a>
    </div>

    {%- if show_trust -%}
      <div class="hero-trust">
        {%- if section.settings.trust_1 != blank -%}
          <span class="trust-item"><span class="trust-icon">🧪</span> {{ section.settings.trust_1 }}</span>
        {%- endif -%}
        {%- if section.settings.trust_2 != blank -%}
          <span class="trust-item"><span class="trust-icon">🌱</span> {{ section.settings.trust_2 }}</span>
        {%- endif -%}
        {%- if section.settings.trust_3 != blank -%}
          <span class="trust-item"><span class="trust-icon">♻️</span> {{ section.settings.trust_3 }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  <div class="hero-visual">
    <div class="hero-visual-inner">
      <div class="hero-blob" style="background-color: {{ visual_bg }}">
        <div class="fc-dot"></div>
        <div class="fc-dot2"></div>
        {%- if section.settings.hero_image != blank -%}
          {{ section.settings.hero_image | img_tag:
              section.settings.hero_image.alt | default: shop.name,
              loading: 'eager',
              class: 'hero-product-img',
              widths: '400, 600, 800',
              sizes: '45vw' }}
        {%- else -%}
          <span class="blob-icon">🌿</span>
          <span class="blob-label">Pure · Potent · Kind</span>
        {%- endif -%}
      </div>
    </div>

    {%- if show_floating -%}
      <div class="hero-floating-card2">
        <div class="hfc2-text">⭐ {{ section.settings.stat_rating }}</div>
        <div class="hfc2-stars">★★★★★ {{ review_count }} reviews</div>
      </div>

      <div class="hero-floating-card">
        <div class="hfc-label">{{ month_label }}</div>
        <div class="hfc-val">{{ section.settings.stat_orders }}</div>
        <div class="hfc-sub">{{ orders_label }}</div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "div",
  "class": "hero-wrapper",
  "settings": [
    { "type": "header",   "content": "Content" },
    { "type": "text",     "id": "eyebrow",            "label": "Eyebrow text",         "default": "New — Spring Wellness Collection" },
    { "type": "text",     "id": "heading",             "label": "Main heading",          "default": "Wellness rooted in nature's wisdom" },
    { "type": "textarea", "id": "subheading",          "label": "Subheading",            "default": "Solmara blends ancient botanical knowledge with modern science." },
    { "type": "header",   "content": "Buttons" },
    { "type": "text",     "id": "btn_primary_label",   "label": "Primary button text",   "default": "Shop the Collection" },
    { "type": "url",      "id": "btn_primary_url",     "label": "Primary button link" },
    { "type": "text",     "id": "btn_secondary_label", "label": "Secondary button text", "default": "Take the Wellness Quiz" },
    { "type": "url",      "id": "btn_secondary_url",   "label": "Secondary button link" },
    { "type": "header",   "content": "Visual" },
    { "type": "image_picker", "id": "hero_image",      "label": "Hero product image (optional)" },
    { "type": "color",    "id": "visual_bg",           "label": "Blob background colour","default": "#F0EBE3" },
    { "type": "header",   "content": "Trust Badges" },
    { "type": "checkbox", "id": "show_trust_badges",   "label": "Show trust badges",     "default": true },
    { "type": "text",     "id": "trust_1",             "label": "Trust badge 1",         "default": "Clinically tested" },
    { "type": "text",     "id": "trust_2",             "label": "Trust badge 2",         "default": "Certified organic" },
    { "type": "text",     "id": "trust_3",             "label": "Trust badge 3",         "default": "Plastic-free packaging" },
    { "type": "header",   "content": "Social Proof Stats" },
    { "type": "text",     "id": "stat_orders",         "label": "Orders shipped stat",   "default": "24,800+" },
    { "type": "text",     "id": "stat_rating",         "label": "Rating stat",           "default": "4.9 / 5 Rating" },
    { "type": "text",     "id": "stat_review_count",   "label": "Review count",          "default": "12,400+" },
    { "type": "header",   "content": "Floating Cards" },
    { "type": "checkbox", "id": "show_floating_cards", "label": "Show floating stat cards","default": true },
    { "type": "text",     "id": "stat_month_label",    "label": "Card label (e.g. 'This Month')", "default": "This Month" },
    { "type": "text",     "id": "stat_orders_label",   "label": "Card sub-label",        "default": "orders shipped worldwide 🌍" }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
