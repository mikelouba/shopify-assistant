<div class="recently-viewed-section" id="recentlyViewed" style="display:none">
  <p class="section-eyebrow" style="text-align:center">✦ Your Journey</p>
  <h2 class="section-title">{{ section.settings.heading }}</h2>
  <div class="products-grid related-grid" id="recentlyViewedGrid"></div>
</div>

<script>
(function() {
  const KEY = 'solmara_recently_viewed';
  const PRODUCT_HANDLE = '{{ product.handle }}';
  const MAX = {{ section.settings.products_to_show }};

  // Save current product
  let viewed = JSON.parse(localStorage.getItem(KEY) || '[]');
  viewed = viewed.filter(h => h !== PRODUCT_HANDLE);
  viewed.unshift(PRODUCT_HANDLE);
  viewed = viewed.slice(0, 8);
  localStorage.setItem(KEY, JSON.stringify(viewed));

  // Show other recently viewed products
  const others = viewed.filter(h => h !== PRODUCT_HANDLE).slice(0, MAX);
  if (others.length === 0) return;

  const sectionEl = document.getElementById('recentlyViewed');
  const grid = document.getElementById('recentlyViewedGrid');
  sectionEl.style.display = 'block';

  // Fetch each product via Shopify AJAX API and render a card
  others.forEach(function(handle) {
    fetch('/products/' + handle + '.js')
      .then(function(r) { return r.json(); })
      .then(function(p) {
        const variant  = p.variants[0];
        const img      = p.featured_image
                           ? '<img src="' + p.featured_image + '" alt="' + p.title.replace(/"/g,"'") + '" loading="lazy" class="p-img">'
                           : '<div class="p-img-bg" style="background:var(--sand)"><span class="p-icon">🌿</span></div>';
        const price    = formatMoney(variant.price);
        const oldPrice = variant.compare_at_price && variant.compare_at_price > variant.price
                           ? '<span class="p-price-old">' + formatMoney(variant.compare_at_price) + '</span>' : '';
        const priceCol = variant.compare_at_price && variant.compare_at_price > variant.price
                           ? 'style="color:var(--terracotta)"' : '';

        const card = '<div class="product-card">' +
          '<a href="/products/' + handle + '" class="p-img-wrap" aria-label="' + p.title.replace(/"/g,"'") + '">' +
            img +
          '</a>' +
          '<div class="p-info">' +
            '<p class="p-cat">' + (p.product_type || 'Wellness') + '</p>' +
            '<a href="/products/' + handle + '"><p class="p-name">' + p.title + '</p></a>' +
            '<div class="p-price-row">' +
              '<span class="p-price" ' + priceCol + '>' + price + '</span>' + oldPrice +
            '</div>' +
          '</div>' +
        '</div>';

        grid.insertAdjacentHTML('beforeend', card);
      })
      .catch(function() {});
  });

  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2);
  }
})();
</script>

{% schema %}
{
  "name": "Recently Viewed",
  "tag": "div",
  "settings": [
    { "type": "text",  "id": "heading",          "label": "Heading",          "default": "Recently Viewed" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 6, "step": 1, "default": 4 }
  ],
  "presets": [{ "name": "Recently Viewed" }]
}
{% endschema %}
