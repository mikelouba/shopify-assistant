<div class="page-container">
  {%- render 'breadcrumbs' -%}
  <div class="page-header">
    <h1 class="page-title">{{ page.title }}</h1>
  </div>
  <div class="page-content rte">
    {{ page.content }}
  </div>
</div>

{% schema %}
{
  "name": "Page",
  "tag": "div",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "narrow_content",
      "label": "Narrow content width",
      "default": false,
      "info": "Limits body text to ~720px for easier reading on long pages"
    },
    {
      "type": "select",
      "id": "title_align",
      "label": "Title alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    }
  ],
  "presets": [{ "name": "Page" }]
}
{% endschema %}
