{% comment %}
  ╔══════════════════════════════════════════════════════════════════════╗
  ║  GOAL PAGE HERO  —  Solmara Wellness                                 ║
  ║  sections/goal-page-hero.liquid                                      ║
  ║                                                                      ║
  ║  Five fully-customisable sections for every goal landing page.       ║
  ║  All settings exposed in the Theme Editor right-hand panel.          ║
  ║                                                                      ║
  ║    §1  HERO        — image, overlay, badge, heading, CTAs           ║
  ║    §2  BENEFITS    — 3-column icon / title / description cards      ║
  ║    §3  PRODUCTS    — collection grid, card style, columns           ║
  ║    §4  TESTIMONIAL — quote, stars, author                           ║
  ║    §5  BOTTOM CTA  — full-width call-to-action banner               ║
  ║                                                                      ║
  ║  Solmara palette · DM Serif Display + Jost · CSS-variable themed    ║
  ╚══════════════════════════════════════════════════════════════════════╝
{% endcomment %}

{%- liquid
  assign s        = section.settings
  assign bg       = s.bg_color
  assign txt      = s.text_color
  assign accent   = s.accent_color
  assign ovl_clr  = s.hero_overlay_color
  assign ovl_dec  = s.hero_overlay_opacity | divided_by: 100.0
  assign rating   = s.testimonial_rating
  assign feat_col = s.collection
  assign p_cols   = s.product_columns    | default: '3'
  assign p_style  = s.product_card_style | default: 'card'
  assign p_limit  = s.products_to_show   | default: 6
  assign card_btn = s.card_btn_text      | default: 'Shop Now'
  assign test_bg  = s.testimonial_bg_color
  assign btm_bg   = s.cta_bottom_bg_color
  assign btm_txt  = s.cta_bottom_text_color
-%}

{%- comment %} ── Scoped styles: every rule is namespaced to this section ID ── {% endcomment -%}
<style>
/* ── RESET ─────────────────────────────────────────────────────────── */
#shopify-section-{{ section.id }} *,
#shopify-section-{{ section.id }} *::before,
#shopify-section-{{ section.id }} *::after { box-sizing: border-box; margin: 0; }

/* ── CSS CUSTOM PROPERTIES (goal color cascade) ─────────────────── */
#shopify-section-{{ section.id }} {
  --gph-bg:       {{ bg }};
  --gph-txt:      {{ txt }};
  --gph-accent:   {{ accent }};
  --gph-ovl:      {{ ovl_clr }};
  --gph-test-bg:  {{ test_bg }};
  --gph-btm-bg:   {{ btm_bg }};
  --gph-btm-txt:  {{ btm_txt }};
}

/* ═══════════════════════════════════════════════════════════════════
   §1  HERO
═══════════════════════════════════════════════════════════════════ */
#shopify-section-{{ section.id }} .gph-hero {
  position: relative;
  overflow: hidden;
  background: var(--gph-bg);
  min-height: 88vh;
  display: flex;
  align-items: center;
}
#shopify-section-{{ section.id }} .gph-hero__img-wrap {
  position: absolute;
  inset: 0;
  z-index: 0;
}
#shopify-section-{{ section.id }} .gph-hero__img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}
#shopify-section-{{ section.id }} .gph-hero__overlay {
  position: absolute;
  inset: 0;
  background: var(--gph-ovl);
  opacity: {{ ovl_dec }};
  pointer-events: none;
  z-index: 1;
}
#shopify-section-{{ section.id }} .gph-hero__grad {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, {{ bg }}, {{ accent }}44, {{ bg }});
  z-index: 0;
}
#shopify-section-{{ section.id }} .gph-hero__content {
  position: relative;
  z-index: 2;
  max-width: 1200px;
  margin: 0 auto;
  padding: 96px 64px;
  width: 100%;
}

/* Badge */
#shopify-section-{{ section.id }} .gph-badge {
  display: inline-flex;
  align-items: center;
  padding: 6px 18px;
  border-radius: 3px;
  margin-bottom: 28px;
  background: {{ s.hero_badge_color }};
}
#shopify-section-{{ section.id }} .gph-badge__label {
  font-family: 'Jost', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 3.5px;
  text-transform: uppercase;
  color: var(--gph-bg);
}

/* Heading & sub */
#shopify-section-{{ section.id }} .gph-h1 {
  font-family: 'DM Serif Display', Georgia, 'Times New Roman', serif;
  font-size: clamp(44px, 6vw, 84px);
  font-weight: 400;
  color: var(--gph-txt);
  line-height: 1.05;
  max-width: 700px;
  margin-bottom: 22px;
  letter-spacing: -0.5px;
}
#shopify-section-{{ section.id }} .gph-sub {
  font-family: 'Jost', sans-serif;
  font-size: 17px;
  font-weight: 300;
  color: {{ txt }}bb;
  line-height: 1.8;
  max-width: 520px;
  margin-bottom: 44px;
}

/* CTA buttons */
#shopify-section-{{ section.id }} .gph-btns {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
}
#shopify-section-{{ section.id }} .gph-btn {
  border-radius: 3px;
  font-family: 'Jost', sans-serif;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  transition: opacity 0.22s ease, border-color 0.22s ease, transform 0.22s ease;
}
#shopify-section-{{ section.id }} .gph-btn--primary {
  background: var(--gph-accent);
  color: var(--gph-bg);
  padding: 16px 40px;
}
#shopify-section-{{ section.id }} .gph-btn--primary:hover {
  opacity: 0.86;
  transform: translateY(-2px);
}
#shopify-section-{{ section.id }} .gph-btn--secondary {
  background: transparent;
  color: var(--gph-txt);
  border: 1.5px solid {{ accent }}55;
  padding: 15px 38px;
}
#shopify-section-{{ section.id }} .gph-btn--secondary:hover {
  border-color: var(--gph-accent);
  transform: translateY(-2px);
}

/* ═══════════════════════════════════════════════════════════════════
   §2  BENEFITS BAR
═══════════════════════════════════════════════════════════════════ */
#shopify-section-{{ section.id }} .gph-benefits {
  background: {{ bg }}ee;
  padding: 76px 64px;
  border-top: 1px solid {{ accent }}22;
  border-bottom: 1px solid {{ accent }}22;
}
#shopify-section-{{ section.id }} .gph-benefits__inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 52px;
}
#shopify-section-{{ section.id }} .gph-benefit-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0;
}
#shopify-section-{{ section.id }} .gph-benefit-card__accent-line {
  width: 36px;
  height: 2px;
  background: var(--gph-accent);
  border-radius: 2px;
  margin-bottom: 20px;
}
#shopify-section-{{ section.id }} .gph-benefit-card__icon {
  font-size: 30px;
  line-height: 1;
  margin-bottom: 16px;
  display: block;
}
#shopify-section-{{ section.id }} .gph-benefit-card__title {
  font-family: 'DM Serif Display', Georgia, serif;
  font-size: 19px;
  font-weight: 400;
  color: var(--gph-txt);
  line-height: 1.3;
  margin-bottom: 10px;
}
#shopify-section-{{ section.id }} .gph-benefit-card__desc {
  font-family: 'Jost', sans-serif;
  font-size: 14px;
  font-weight: 300;
  color: {{ txt }}88;
  line-height: 1.75;
}

/* ═══════════════════════════════════════════════════════════════════
   §3  PRODUCTS GRID
═══════════════════════════════════════════════════════════════════ */
#shopify-section-{{ section.id }} .gph-products {
  background: #f7f4ef;
  padding: 96px 64px;
}
#shopify-section-{{ section.id }} .gph-products__inner {
  max-width: 1200px;
  margin: 0 auto;
}
#shopify-section-{{ section.id }} .gph-products__hd {
  text-align: center;
  margin-bottom: 64px;
}
#shopify-section-{{ section.id }} .gph-products__heading {
  font-family: 'DM Serif Display', Georgia, serif;
  font-size: clamp(26px, 3vw, 44px);
  font-weight: 400;
  color: {{ bg }};
  margin-bottom: 14px;
  letter-spacing: -0.3px;
}
#shopify-section-{{ section.id }} .gph-products__subheading {
  font-family: 'Jost', sans-serif;
  font-size: 15px;
  font-weight: 300;
  color: {{ bg }}99;
  max-width: 480px;
  margin: 0 auto;
  line-height: 1.7;
}
#shopify-section-{{ section.id }} .gph-products__grid {
  display: grid;
  gap: 24px;
  grid-template-columns: repeat({{ p_cols }}, 1fr);
}
#shopify-section-{{ section.id }} .gph-products__footer {
  text-align: center;
  margin-top: 56px;
}
#shopify-section-{{ section.id }} .gph-products__view-all {
  font-family: 'Jost', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: {{ bg }};
  text-decoration: none;
  border-bottom: 1.5px solid var(--gph-accent);
  padding-bottom: 3px;
  transition: color 0.2s, border-color 0.2s;
}
#shopify-section-{{ section.id }} .gph-products__view-all:hover {
  color: var(--gph-accent);
  border-color: var(--gph-accent);
}

/* ── Product Cards ────────────────────────────────────────────────── */
#shopify-section-{{ section.id }} .gph-card {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
#shopify-section-{{ section.id }} .gph-card:hover {
  transform: translateY(-5px);
}

/* Card style: card (shadow) */
#shopify-section-{{ section.id }} .gph-card--card {
  background: #ffffff;
  border-radius: 10px;
  box-shadow: 0 2px 18px rgba(0,0,0,0.07);
}
#shopify-section-{{ section.id }} .gph-card--card:hover {
  box-shadow: 0 10px 44px rgba(0,0,0,0.13);
}

/* Card style: minimal */
#shopify-section-{{ section.id }} .gph-card--minimal {
  background: transparent;
  border-radius: 0;
}

/* Card style: bordered */
#shopify-section-{{ section.id }} .gph-card--bordered {
  background: #ffffff;
  border-radius: 8px;
  border: 1.5px solid {{ accent }}44;
}
#shopify-section-{{ section.id }} .gph-card--bordered:hover {
  border-color: var(--gph-accent);
  box-shadow: 0 6px 28px rgba(0,0,0,0.08);
}

/* Image */
#shopify-section-{{ section.id }} .gph-card__img-link {
  display: block;
  text-decoration: none;
  position: relative;
  overflow: hidden;
}
#shopify-section-{{ section.id }} .gph-card__img-wrap {
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: #f2f0ec;
  display: flex;
  align-items: center;
  justify-content: center;
}
#shopify-section-{{ section.id }} .gph-card--minimal .gph-card__img-wrap {
  background: {{ accent }}12;
}
#shopify-section-{{ section.id }} .gph-card__img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
  transition: transform 0.45s ease;
  display: block;
}
#shopify-section-{{ section.id }} .gph-card:hover .gph-card__img-wrap img {
  transform: scale(1.05);
}
#shopify-section-{{ section.id }} .gph-card__sale-badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: var(--gph-accent);
  color: var(--gph-bg);
  font-family: 'Jost', sans-serif;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 2px;
  pointer-events: none;
}

/* Card body */
#shopify-section-{{ section.id }} .gph-card__body {
  padding: 20px 20px 12px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  flex: 1;
}
#shopify-section-{{ section.id }} .gph-card--minimal .gph-card__body {
  padding: 16px 0 8px;
}
#shopify-section-{{ section.id }} .gph-card__title {
  font-family: 'DM Serif Display', Georgia, serif;
  font-size: 16px;
  font-weight: 400;
  color: #1a2520;
  line-height: 1.35;
  text-decoration: none;
  display: block;
  transition: color 0.2s;
}
#shopify-section-{{ section.id }} .gph-card__title:hover {
  color: {{ bg }};
}
#shopify-section-{{ section.id }} .gph-card__price-row {
  display: flex;
  align-items: baseline;
  gap: 8px;
  flex-wrap: wrap;
}
#shopify-section-{{ section.id }} .gph-card__price {
  font-family: 'Jost', sans-serif;
  font-size: 14px;
  font-weight: 500;
  color: {{ bg }};
}
#shopify-section-{{ section.id }} .gph-card__compare {
  font-family: 'Jost', sans-serif;
  font-size: 12px;
  font-weight: 400;
  color: #aaa;
  text-decoration: line-through;
}

/* Card footer / CTA */
#shopify-section-{{ section.id }} .gph-card__footer {
  padding: 0 20px 20px;
}
#shopify-section-{{ section.id }} .gph-card--minimal .gph-card__footer {
  padding: 4px 0 0;
}
#shopify-section-{{ section.id }} .gph-card__cta-form { margin: 0; }
#shopify-section-{{ section.id }} .gph-card__btn {
  display: block;
  width: 100%;
  text-align: center;
  background: var(--gph-bg);
  color: var(--gph-txt);
  border: none;
  border-radius: 4px;
  padding: 12px 16px;
  font-family: 'Jost', sans-serif;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  cursor: pointer;
  text-decoration: none;
  transition: opacity 0.2s ease, transform 0.2s ease;
  line-height: 1;
}
#shopify-section-{{ section.id }} .gph-card__btn:hover {
  opacity: 0.84;
  transform: translateY(-1px);
}

/* ═══════════════════════════════════════════════════════════════════
   §4  TESTIMONIAL
═══════════════════════════════════════════════════════════════════ */
#shopify-section-{{ section.id }} .gph-testimonial {
  background: var(--gph-test-bg);
  padding: 96px 64px;
  border-top: 1px solid {{ accent }}22;
}
#shopify-section-{{ section.id }} .gph-testimonial__inner {
  max-width: 720px;
  margin: 0 auto;
  text-align: center;
}
#shopify-section-{{ section.id }} .gph-testimonial__stars {
  color: var(--gph-accent);
  font-size: 20px;
  letter-spacing: 5px;
  display: block;
  margin-bottom: 32px;
}
#shopify-section-{{ section.id }} .gph-testimonial__quote {
  font-family: 'DM Serif Display', Georgia, serif;
  font-style: italic;
  font-size: clamp(18px, 2.5vw, 27px);
  line-height: 1.65;
  color: var(--gph-txt);
  display: block;
  margin-bottom: 32px;
}
#shopify-section-{{ section.id }} .gph-testimonial__author {
  font-family: 'Jost', sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--gph-accent);
  font-style: normal;
  display: block;
}
#shopify-section-{{ section.id }} .gph-testimonial__subtitle {
  font-family: 'Jost', sans-serif;
  font-size: 11px;
  font-weight: 400;
  letter-spacing: 0.5px;
  color: {{ txt }}66;
  font-style: normal;
  display: block;
  margin-top: 6px;
}

/* ═══════════════════════════════════════════════════════════════════
   §5  BOTTOM CTA BANNER
═══════════════════════════════════════════════════════════════════ */
#shopify-section-{{ section.id }} .gph-cta-bottom {
  background: var(--gph-btm-bg);
  padding: 88px 64px;
  text-align: center;
}
#shopify-section-{{ section.id }} .gph-cta-bottom__inner {
  max-width: 660px;
  margin: 0 auto;
}
#shopify-section-{{ section.id }} .gph-cta-bottom__heading {
  font-family: 'DM Serif Display', Georgia, serif;
  font-size: clamp(28px, 3.5vw, 48px);
  font-weight: 400;
  color: var(--gph-btm-txt);
  line-height: 1.15;
  margin-bottom: 16px;
  letter-spacing: -0.3px;
}
#shopify-section-{{ section.id }} .gph-cta-bottom__subtext {
  font-family: 'Jost', sans-serif;
  font-size: 16px;
  font-weight: 300;
  color: {{ btm_txt }}bb;
  line-height: 1.7;
  margin-bottom: 40px;
}
#shopify-section-{{ section.id }} .gph-cta-bottom__btn {
  display: inline-flex;
  align-items: center;
  background: var(--gph-btm-txt);
  color: var(--gph-btm-bg);
  border: none;
  border-radius: 3px;
  padding: 18px 52px;
  font-family: 'Jost', sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  text-decoration: none;
  cursor: pointer;
  transition: opacity 0.22s ease, transform 0.22s ease;
}
#shopify-section-{{ section.id }} .gph-cta-bottom__btn:hover {
  opacity: 0.86;
  transform: translateY(-2px);
}

/* ═══════════════════════════════════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════════════════════════════════ */
@media (max-width: 1024px) {
  #shopify-section-{{ section.id }} .gph-benefits__inner {
    gap: 36px;
  }
}
@media (max-width: 768px) {
  #shopify-section-{{ section.id }} .gph-hero__content {
    padding: 72px 24px 64px;
  }
  #shopify-section-{{ section.id }} .gph-benefits {
    padding: 56px 24px;
  }
  #shopify-section-{{ section.id }} .gph-benefits__inner {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  #shopify-section-{{ section.id }} .gph-products {
    padding: 64px 24px;
  }
  #shopify-section-{{ section.id }} .gph-products__grid {
    grid-template-columns: repeat(2, 1fr) !important;
  }
  #shopify-section-{{ section.id }} .gph-testimonial {
    padding: 64px 24px;
  }
  #shopify-section-{{ section.id }} .gph-cta-bottom {
    padding: 64px 24px;
  }
}
@media (max-width: 480px) {
  #shopify-section-{{ section.id }} .gph-btns {
    flex-direction: column;
    align-items: flex-start;
  }
  #shopify-section-{{ section.id }} .gph-btn--primary,
  #shopify-section-{{ section.id }} .gph-btn--secondary {
    justify-content: center;
    width: 100%;
  }
  #shopify-section-{{ section.id }} .gph-products__grid {
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 16px;
  }
}
</style>

{%- comment %} ═══════════════════════════════════════════════════════════
    §1  HERO
═══════════════════════════════════════════════════════════ {% endcomment -%}
<div class="gph-hero">

  {%- if s.hero_image != blank -%}
    <div class="gph-hero__img-wrap">
      <img
        src="{{ s.hero_image | image_url: width: 1800 }}"
        alt="{{ s.hero_image.alt | escape }}"
        loading="eager"
        width="{{ s.hero_image.width }}"
        height="{{ s.hero_image.height }}"
      >
    </div>
    <div class="gph-hero__overlay"></div>
  {%- else -%}
    <div class="gph-hero__grad"></div>
  {%- endif -%}

  <div class="gph-hero__content">

    {%- if s.hero_badge != blank -%}
      <div class="gph-badge">
        <span class="gph-badge__label">{{ s.hero_badge }}</span>
      </div>
    {%- endif -%}

    {%- if s.hero_heading != blank -%}
      <h1 class="gph-h1">{{ s.hero_heading }}</h1>
    {%- endif -%}

    {%- if s.hero_subheading != blank -%}
      <p class="gph-sub">{{ s.hero_subheading }}</p>
    {%- endif -%}

    {%- if s.cta_primary_text != blank or s.cta_secondary_text != blank -%}
      <div class="gph-btns">
        {%- if s.cta_primary_text != blank -%}
          <a href="{{ s.cta_primary_url | default: '#' }}" class="gph-btn gph-btn--primary">
            {{ s.cta_primary_text }}
          </a>
        {%- endif -%}
        {%- if s.cta_secondary_text != blank -%}
          <a href="{{ s.cta_secondary_url | default: '#' }}" class="gph-btn gph-btn--secondary">
            {{ s.cta_secondary_text }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</div>

{%- comment %} ═══════════════════════════════════════════════════════════
    §2  BENEFITS BAR
═══════════════════════════════════════════════════════════ {% endcomment -%}
{%- assign has_benefits = false -%}
{%- if s.benefit_1_title != blank or s.benefit_2_title != blank or s.benefit_3_title != blank -%}
  {%- assign has_benefits = true -%}
{%- endif -%}
{%- if has_benefits -%}
  <div class="gph-benefits">
    <div class="gph-benefits__inner">

      {%- if s.benefit_1_title != blank -%}
        <div class="gph-benefit-card">
          <div class="gph-benefit-card__accent-line"></div>
          {%- if s.benefit_1_icon != blank -%}
            <span class="gph-benefit-card__icon" aria-hidden="true">{{ s.benefit_1_icon }}</span>
          {%- endif -%}
          <h3 class="gph-benefit-card__title">{{ s.benefit_1_title }}</h3>
          {%- if s.benefit_1_desc != blank -%}
            <p class="gph-benefit-card__desc">{{ s.benefit_1_desc }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if s.benefit_2_title != blank -%}
        <div class="gph-benefit-card">
          <div class="gph-benefit-card__accent-line"></div>
          {%- if s.benefit_2_icon != blank -%}
            <span class="gph-benefit-card__icon" aria-hidden="true">{{ s.benefit_2_icon }}</span>
          {%- endif -%}
          <h3 class="gph-benefit-card__title">{{ s.benefit_2_title }}</h3>
          {%- if s.benefit_2_desc != blank -%}
            <p class="gph-benefit-card__desc">{{ s.benefit_2_desc }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if s.benefit_3_title != blank -%}
        <div class="gph-benefit-card">
          <div class="gph-benefit-card__accent-line"></div>
          {%- if s.benefit_3_icon != blank -%}
            <span class="gph-benefit-card__icon" aria-hidden="true">{{ s.benefit_3_icon }}</span>
          {%- endif -%}
          <h3 class="gph-benefit-card__title">{{ s.benefit_3_title }}</h3>
          {%- if s.benefit_3_desc != blank -%}
            <p class="gph-benefit-card__desc">{{ s.benefit_3_desc }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>
{%- endif -%}

{%- comment %} ═══════════════════════════════════════════════════════════
    §3  PRODUCTS GRID
    Renders products from the selected collection.
    Fully configurable: columns, count, card style, price, ATC button.
═══════════════════════════════════════════════════════════ {% endcomment -%}
{%- if feat_col != blank and feat_col.products_count > 0 -%}
  <div class="gph-products">
    <div class="gph-products__inner">

      <div class="gph-products__hd">
        {%- if s.products_heading != blank -%}
          <h2 class="gph-products__heading">{{ s.products_heading }}</h2>
        {%- endif -%}
        {%- if s.products_subheading != blank -%}
          <p class="gph-products__subheading">{{ s.products_subheading }}</p>
        {%- endif -%}
      </div>

      <div class="gph-products__grid">
        {%- for product in collections[feat_col.handle].products limit: p_limit -%}
          <article class="gph-card gph-card--{{ p_style }}">

            <a href="{{ product.url }}" class="gph-card__img-link" aria-label="{{ product.title | escape }}">
              <div class="gph-card__img-wrap">
                {%- if product.featured_image != blank -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | escape | default: product.title }}"
                    loading="lazy"
                    width="600"
                    height="600"
                    style="object-fit: contain; object-position: center center; width: 100%; height: 100%;"
                  >
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'gph-card__placeholder' }}
                {%- endif -%}
              </div>
              {%- if product.compare_at_price > product.price -%}
                <span class="gph-card__sale-badge">Sale</span>
              {%- endif -%}
            </a>

            <div class="gph-card__body">
              <a href="{{ product.url }}" class="gph-card__title">{{ product.title }}</a>
              {%- if s.show_price -%}
                <div class="gph-card__price-row">
                  <span class="gph-card__price">{{ product.price | money }}</span>
                  {%- if product.compare_at_price > product.price -%}
                    <span class="gph-card__compare">{{ product.compare_at_price | money }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>

            <div class="gph-card__footer">
              {%- if s.show_add_to_cart and product.first_available_variant != blank -%}
                <form action="/cart/add" method="post" class="gph-card__cta-form">
                  <input type="hidden" name="id" value="{{ product.first_available_variant.id }}">
                  <input type="hidden" name="quantity" value="1">
                  <button type="submit" class="gph-card__btn">{{ card_btn }}</button>
                </form>
              {%- else -%}
                <a href="{{ product.url }}" class="gph-card__btn">{{ card_btn }}</a>
              {%- endif -%}
            </div>

          </article>
        {%- endfor -%}
      </div>

      <div class="gph-products__footer">
        <a href="{{ feat_col.url }}" class="gph-products__view-all">
          View Full Collection &rarr;
        </a>
      </div>

    </div>
  </div>
{%- endif -%}

{%- comment %} ═══════════════════════════════════════════════════════════
    §4  TESTIMONIAL
═══════════════════════════════════════════════════════════ {% endcomment -%}
{%- if s.show_testimonial and s.testimonial_text != blank -%}
  <div class="gph-testimonial">
    <div class="gph-testimonial__inner">

      <span class="gph-testimonial__stars" aria-label="{{ rating }} out of 5 stars">
        {%- for i in (1..5) -%}
          {%- if i <= rating -%}&#9733;{%- else -%}&#9734;{%- endif -%}
        {%- endfor -%}
      </span>

      <blockquote class="gph-testimonial__quote">
        &ldquo;{{ s.testimonial_text }}&rdquo;
      </blockquote>

      {%- if s.testimonial_author != blank -%}
        <cite class="gph-testimonial__author">— {{ s.testimonial_author }}</cite>
      {%- endif -%}
      {%- if s.testimonial_author_subtitle != blank -%}
        <span class="gph-testimonial__subtitle">{{ s.testimonial_author_subtitle }}</span>
      {%- endif -%}

    </div>
  </div>
{%- endif -%}

{%- comment %} ═══════════════════════════════════════════════════════════
    §5  BOTTOM CTA BANNER
═══════════════════════════════════════════════════════════ {% endcomment -%}
{%- if s.cta_bottom_heading != blank or s.cta_bottom_btn_text != blank -%}
  <div class="gph-cta-bottom">
    <div class="gph-cta-bottom__inner">

      {%- if s.cta_bottom_heading != blank -%}
        <h2 class="gph-cta-bottom__heading">{{ s.cta_bottom_heading }}</h2>
      {%- endif -%}

      {%- if s.cta_bottom_subtext != blank -%}
        <p class="gph-cta-bottom__subtext">{{ s.cta_bottom_subtext }}</p>
      {%- endif -%}

      {%- if s.cta_bottom_btn_text != blank -%}
        <a
          href="{{ s.cta_bottom_btn_url | default: '#' }}"
          class="gph-cta-bottom__btn"
        >{{ s.cta_bottom_btn_text }}</a>
      {%- endif -%}

    </div>
  </div>
{%- endif -%}


