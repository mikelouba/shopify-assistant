{%- liquid
  assign bg_color      = section.settings.bg_color      | default: '#F8F5F0'
  assign cols          = section.settings.cols          | default: '3'
  assign show_verified = section.settings.show_verified | default: true
  assign pad           = section.settings.section_padding | default: 60
-%}

<section class="testimonials-section"
  style="background-color: {{ bg_color }}; padding-top: {{ pad }}px; padding-bottom: {{ pad }}px;">
  <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
  <h2 class="section-title">{{ section.settings.heading | replace: 'feels', '<em>feels</em>' }}</h2>

  <div class="testimonials-grid" style="grid-template-columns: repeat({{ cols }}, 1fr);">
    {%- for block in section.blocks -%}
      <div class="testimonial-card" {{ block.shopify_attributes }}>
        <div class="t-stars">
          {%- assign stars = block.settings.stars | times: 1 -%}
          {%- for i in (1..5) -%}
            {%- if i <= stars -%}★{%- else -%}☆{%- endif -%}
          {%- endfor -%}
        </div>
        <p class="t-text">&#8220;{{ block.settings.text }}&#8221;</p>
        <div class="t-footer">
          <div class="t-avatar">{{ block.settings.avatar }}</div>
          <div>
            <div class="t-author">{{ block.settings.author }}</div>
            <div class="t-meta">Verified Customer · {{ block.settings.location }}</div>
            {%- if show_verified -%}
              <div class="t-verified">✓ Verified Purchase</div>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "div",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text",   "id": "eyebrow", "label": "Eyebrow", "default": "✦ Real Results" },
    { "type": "text",   "id": "heading", "label": "Heading", "default": "What our community feels" },
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "cols",
      "label": "Columns",
      "options": [
        { "value": "1", "label": "1 column (stacked)" },
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" }
      ],
      "default": "3",
      "info": "Collapses to a single column on mobile."
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 20, "max": 100, "step": 10, "unit": "px",
      "default": 60
    },
    { "type": "header",   "content": "Style" },
    { "type": "color",    "id": "bg_color",      "label": "Background colour", "default": "#F8F5F0" },
    { "type": "checkbox", "id": "show_verified",  "label": "Show Verified Purchase badge", "default": true }
  ],
  "blocks": [{
    "type": "testimonial",
    "name": "Testimonial",
    "settings": [
      { "type": "range",    "id": "stars",    "label": "Stars",         "min": 1, "max": 5, "step": 1, "default": 5 },
      { "type": "textarea", "id": "text",     "label": "Review text" },
      { "type": "text",     "id": "author",   "label": "Customer name", "default": "Happy Customer" },
      { "type": "text",     "id": "location", "label": "Location",      "default": "United States" },
      { "type": "text",     "id": "avatar",   "label": "Avatar emoji",  "default": "🌿" }
    ]
  }],
  "presets": [{ "name": "Testimonials" }]
}
{% endschema %}
