{%- liquid
  assign bg_color      = section.settings.bg_color      | default: '#F8F5F0'
  assign cols          = section.settings.cols          | default: '3'
  assign show_verified = section.settings.show_verified | default: true
-%}

<style>
  .tst-{{ section.id }} {
    padding-top:    {{ section.settings.pad_top }}px !important;
    padding-bottom: {{ section.settings.pad_bottom }}px !important;
    padding-left:   {{ section.settings.pad_left }}px !important;
    padding-right:  {{ section.settings.pad_right }}px !important;
  }
  @media (max-width: 768px) {
    .tst-{{ section.id }} {
      padding-top:    {{ section.settings.mob_pad_top }}px !important;
      padding-bottom: {{ section.settings.mob_pad_bottom }}px !important;
      padding-left:   {{ section.settings.mob_pad_left }}px !important;
      padding-right:  {{ section.settings.mob_pad_right }}px !important;
    }
  }
</style>
<section class="testimonials-section tst-{{ section.id }}"
  style="background-color: {{ bg_color }};">
  <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
  <h2 class="section-title">{{ section.settings.heading | replace: 'feels', '<em>feels</em>' }}</h2>

  <div class="testimonials-grid" style="grid-template-columns: repeat({{ cols }}, 1fr);">
    {%- for block in section.blocks -%}
      <div class="testimonial-card" {{ block.shopify_attributes }}>
        <div class="t-stars">
          {%- assign stars = block.settings.stars | times: 1 -%}
          {%- for i in (1..5) -%}
            {%- if i <= stars -%}★{%- else -%}☆{%- endif -%}
          {%- endfor -%}
        </div>
        <p class="t-text">&#8220;{{ block.settings.text }}&#8221;</p>
        <div class="t-footer">
          <div class="t-avatar">{{ block.settings.avatar }}</div>
          <div>
            <div class="t-author">{{ block.settings.author }}</div>
            <div class="t-meta">Verified Customer · {{ block.settings.location }}</div>
            {%- if show_verified -%}
              <div class="t-verified">✓ Verified Purchase</div>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "div",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text",   "id": "eyebrow", "label": "Eyebrow", "default": "✦ Real Results" },
    { "type": "text",   "id": "heading", "label": "Heading", "default": "What our community feels" },
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "cols",
      "label": "Columns",
      "options": [
        { "value": "1", "label": "1 column (stacked)" },
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" }
      ],
      "default": "3",
      "info": "Collapses to a single column on mobile."
    },
        { "type": "header", "content": "── SPACING ──" },
    { "type": "paragraph", "content": "Desktop padding (applies above 768px)" },
    { "type": "range", "id": "pad_top",        "label": "Desktop top (px)",    "min": 0, "max": 200, "step": 4, "default": 60 },
    { "type": "range", "id": "pad_bottom",     "label": "Desktop bottom (px)", "min": 0, "max": 200, "step": 4, "default": 60 },
    { "type": "range", "id": "pad_left",       "label": "Desktop left (px)",   "min": 0, "max": 160, "step": 4, "default": 0 },
    { "type": "range", "id": "pad_right",      "label": "Desktop right (px)",  "min": 0, "max": 160, "step": 4, "default": 0 },
    { "type": "paragraph", "content": "Mobile padding (applies at ≤768px)" },
    { "type": "range", "id": "mob_pad_top",    "label": "Mobile top (px)",     "min": 0, "max": 120, "step": 4, "default": 40 },
    { "type": "range", "id": "mob_pad_bottom", "label": "Mobile bottom (px)",  "min": 0, "max": 120, "step": 4, "default": 40 },
    { "type": "range", "id": "mob_pad_left",   "label": "Mobile left (px)",    "min": 0, "max": 80,  "step": 4, "default": 0 },
    { "type": "range", "id": "mob_pad_right",  "label": "Mobile right (px)",   "min": 0, "max": 80,  "step": 4, "default": 0 },
    { "type": "header",   "content": "Style" },
    { "type": "color",    "id": "bg_color",      "label": "Background colour", "default": "#F8F5F0" },
    { "type": "checkbox", "id": "show_verified",  "label": "Show Verified Purchase badge", "default": true }
  ],
  "blocks": [{
    "type": "testimonial",
    "name": "Testimonial",
    "settings": [
      { "type": "range",    "id": "stars",    "label": "Stars",         "min": 1, "max": 5, "step": 1, "default": 5 },
      { "type": "textarea", "id": "text",     "label": "Review text" },
      { "type": "text",     "id": "author",   "label": "Customer name", "default": "Happy Customer" },
      { "type": "text",     "id": "location", "label": "Location",      "default": "United States" },
      { "type": "text",     "id": "avatar",   "label": "Avatar emoji",  "default": "🌿" }
    ]
  }],
  "presets": [{ "name": "Testimonials" }]
}
{% endschema %}
