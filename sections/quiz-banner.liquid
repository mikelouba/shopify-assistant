{%- liquid
  assign bg_color    = section.settings.bg_color    | default: '#2D4A30'
  assign text_color  = section.settings.text_color  | default: '#ffffff'
  assign show_eyebrow = section.settings.show_eyebrow | default: true
-%}

<style>
  .qbz-{{ section.id }} {
    padding-top:    {{ section.settings.pad_top }}px !important;
    padding-bottom: {{ section.settings.pad_bottom }}px !important;
    padding-left:   {{ section.settings.pad_left }}px !important;
    padding-right:  {{ section.settings.pad_right }}px !important;
  }
  @media (max-width: 768px) {
    .qbz-{{ section.id }} {
      padding-top:    {{ section.settings.mob_pad_top }}px !important;
      padding-bottom: {{ section.settings.mob_pad_bottom }}px !important;
      padding-left:   {{ section.settings.mob_pad_left }}px !important;
      padding-right:  {{ section.settings.mob_pad_right }}px !important;
    }
  }
</style>
<section class="quiz-banner qbz-{{ section.id }}" id="quiz"
  style="background-color: {{ bg_color }}; color: {{ text_color }};">
  {%- if show_eyebrow and section.settings.eyebrow != blank -%}
    <p class="section-eyebrow" style="color: {{ text_color }}; opacity: 0.8">{{ section.settings.eyebrow }}</p>
  {%- endif -%}
  <h2 class="quiz-title" style="color: {{ text_color }}">{{ section.settings.heading }}</h2>
  <p class="quiz-sub" style="color: {{ text_color }}; opacity: 0.85">{{ section.settings.subheading }}</p>
  <a class="btn-quiz" href="{{ section.settings.btn_url }}" style="color: {{ bg_color }}">{{ section.settings.btn_label }}</a>
</section>

{% schema %}
{
  "name": "Quiz Banner",
  "tag": "div",
  "settings": [
    { "type": "header",   "content": "Content" },
    { "type": "text",     "id": "eyebrow",     "label": "Eyebrow",    "default": "✦ 60 Seconds to Clarity" },
    { "type": "text",     "id": "heading",     "label": "Heading",    "default": "Not sure where to start? Let your body guide you." },
    { "type": "textarea", "id": "subheading",  "label": "Subheading" },
    { "type": "text",     "id": "btn_label",   "label": "Button text","default": "Take the Free Quiz →" },
    { "type": "url",      "id": "btn_url",     "label": "Button link" },
    { "type": "header",   "content": "Layout" },
        { "type": "header", "content": "── SPACING ──" },
    { "type": "paragraph", "content": "Desktop padding (applies above 768px)" },
    { "type": "range", "id": "pad_top",        "label": "Desktop top (px)",    "min": 0, "max": 200, "step": 4, "default": 60 },
    { "type": "range", "id": "pad_bottom",     "label": "Desktop bottom (px)", "min": 0, "max": 200, "step": 4, "default": 60 },
    { "type": "range", "id": "pad_left",       "label": "Desktop left (px)",   "min": 0, "max": 160, "step": 4, "default": 0 },
    { "type": "range", "id": "pad_right",      "label": "Desktop right (px)",  "min": 0, "max": 160, "step": 4, "default": 0 },
    { "type": "paragraph", "content": "Mobile padding (applies at ≤768px)" },
    { "type": "range", "id": "mob_pad_top",    "label": "Mobile top (px)",     "min": 0, "max": 120, "step": 4, "default": 40 },
    { "type": "range", "id": "mob_pad_bottom", "label": "Mobile bottom (px)",  "min": 0, "max": 120, "step": 4, "default": 40 },
    { "type": "range", "id": "mob_pad_left",   "label": "Mobile left (px)",    "min": 0, "max": 80,  "step": 4, "default": 0 },
    { "type": "range", "id": "mob_pad_right",  "label": "Mobile right (px)",   "min": 0, "max": 80,  "step": 4, "default": 0 },
    { "type": "header",   "content": "Style" },
    { "type": "color",    "id": "bg_color",    "label": "Background colour", "default": "#2D4A30",
      "info": "Try forest green #2D4A30, sage #6B8F71, sand #C4A882, or cream #FAF6F0" },
    { "type": "color",    "id": "text_color",  "label": "Text colour",       "default": "#ffffff" },
    { "type": "checkbox", "id": "show_eyebrow","label": "Show eyebrow text", "default": true }
  ],
  "presets": [{ "name": "Quiz Banner" }]
}
{% endschema %}
