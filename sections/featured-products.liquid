{%- liquid
  assign collection     = collections[section.settings.collection]
  assign products_to_show = section.settings.products_to_show | default: 8
  assign grid_cols      = section.settings.grid_cols      | default: '4'
  assign heading_align  = section.settings.heading_align  | default: 'left'
  assign bg_color       = section.settings.bg_color       | default: '#ffffff'
  assign view_all_label = section.settings.view_all_label | default: 'View All →'
  assign show_quick_add = section.settings.show_quick_add
-%}

<style>
  .fps-{{ section.id }} {
    padding-top:    {{ section.settings.pad_top }}px !important;
    padding-bottom: {{ section.settings.pad_bottom }}px !important;
    padding-left:   {{ section.settings.pad_left }}px !important;
    padding-right:  {{ section.settings.pad_right }}px !important;
  }
  @media (max-width: 768px) {
    .fps-{{ section.id }} {
      padding-top:    {{ section.settings.mob_pad_top }}px !important;
      padding-bottom: {{ section.settings.mob_pad_bottom }}px !important;
      padding-left:   {{ section.settings.mob_pad_left }}px !important;
      padding-right:  {{ section.settings.mob_pad_right }}px !important;
    }
  }
</style>
<section class="products-section fps-{{ section.id }}" id="products"
  style="background-color: {{ bg_color }};">

  <div class="section-header-row">
    <div>
      <p class="section-eyebrow" style="text-align: {{ heading_align }}">{{ section.settings.eyebrow }}</p>
      <h2 class="section-title" style="text-align: {{ heading_align }}; margin-bottom: 0">{{ section.settings.heading }}</h2>
    </div>
    <a class="view-all-link" href="{{ section.settings.view_all_url | default: routes.collections_url }}">{{ view_all_label }}</a>
  </div>

  <div class="products-grid" style="grid-template-columns: repeat({{ grid_cols }}, 1fr);">
    {%- if collection != blank and collection.products.size > 0 -%}
      {%- for product in collection.products limit: products_to_show -%}
        {%- render 'product-card', product: product, show_quick_add: show_quick_add -%}
      {%- endfor -%}
    {%- else -%}
      {%- comment -%} Fallback placeholder cards for the theme editor {%- endcomment -%}
      {%- for i in (1..8) -%}
        <div class="product-card">
          <div class="p-img-wrap">
            <div class="p-img-bg" style="background: var(--sand)">
              <span class="p-icon">🌿</span>
              <span>Your Product</span>
            </div>
          </div>
          <div class="p-info">
            <p class="p-cat">Category</p>
            <p class="p-name">Product Name</p>
            <div class="p-price-row"><span class="p-price">$00.00</span></div>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "tag": "div",
  "settings": [
    { "type": "header",     "content": "Content" },
    { "type": "text",       "id": "eyebrow",          "label": "Eyebrow text",        "default": "✦ Most Loved" },
    { "type": "text",       "id": "heading",           "label": "Section heading",     "default": "Our Bestsellers" },
    { "type": "collection", "id": "collection",        "label": "Collection to display" },
    { "type": "range",      "id": "products_to_show",  "label": "Products to show",    "min": 4, "max": 12, "step": 4, "default": 8 },
    { "type": "url",        "id": "view_all_url",      "label": "View all link" },
    { "type": "text",       "id": "view_all_label",    "label": "View all label",      "default": "View All →" },
    { "type": "header",     "content": "Layout" },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Heading alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "grid_cols",
      "label": "Grid columns",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "4",
      "info": "On mobile, columns automatically collapse to 1–2."
    },
        { "type": "header", "content": "── SPACING ──" },
    { "type": "paragraph", "content": "Desktop padding (applies above 768px)" },
    { "type": "range", "id": "pad_top",        "label": "Desktop top (px)",    "min": 0, "max": 200, "step": 4, "default": 60 },
    { "type": "range", "id": "pad_bottom",     "label": "Desktop bottom (px)", "min": 0, "max": 200, "step": 4, "default": 60 },
    { "type": "range", "id": "pad_left",       "label": "Desktop left (px)",   "min": 0, "max": 160, "step": 4, "default": 0 },
    { "type": "range", "id": "pad_right",      "label": "Desktop right (px)",  "min": 0, "max": 160, "step": 4, "default": 0 },
    { "type": "paragraph", "content": "Mobile padding (applies at ≤768px)" },
    { "type": "range", "id": "mob_pad_top",    "label": "Mobile top (px)",     "min": 0, "max": 120, "step": 4, "default": 40 },
    { "type": "range", "id": "mob_pad_bottom", "label": "Mobile bottom (px)",  "min": 0, "max": 120, "step": 4, "default": 40 },
    { "type": "range", "id": "mob_pad_left",   "label": "Mobile left (px)",    "min": 0, "max": 80,  "step": 4, "default": 0 },
    { "type": "range", "id": "mob_pad_right",  "label": "Mobile right (px)",   "min": 0, "max": 80,  "step": 4, "default": 0 },
    { "type": "header",   "content": "Style" },
    { "type": "color",    "id": "bg_color",      "label": "Background colour", "default": "#ffffff" },
    { "type": "checkbox", "id": "show_quick_add", "label": "Show quick-add button on hover", "default": true }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
