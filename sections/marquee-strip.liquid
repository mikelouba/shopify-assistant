{%- liquid
  assign bg_color   = section.settings.bg_color   | default: '#2D4A30'
  assign text_color = section.settings.text_color | default: '#ffffff'
  assign speed      = section.settings.speed      | default: 30
  assign font_size  = section.settings.font_size  | default: 14
  assign separator  = section.settings.separator  | default: 'leaf'
  case separator
    when 'dot'
      assign sep_char = '·'
    when 'dash'
      assign sep_char = '—'
    else
      assign sep_char = '🌿'
  endcase
-%}

<div class="marquee-strip"
  style="background-color: {{ bg_color }}; color: {{ text_color }}; font-size: {{ font_size }}px;">
  <div class="m-track" style="animation-duration: {{ speed }}s" aria-hidden="true">
    {%- assign items = section.settings.items | split: ',' -%}
    {%- comment -%} Duplicate for seamless loop {%- endcomment -%}
    {%- for pass in (1..2) -%}
      {%- for item in items -%}
        <span class="m-item">{{ item | strip }} <span class="m-sep">{{ sep_char }}</span></span>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Marquee Strip",
  "tag": "div",
  "settings": [
    { "type": "header", "content": "Content" },
    {
      "type": "text",
      "id": "items",
      "label": "Items (comma-separated)",
      "default": "Gut Health,Sleep Support,Stress Relief,Immune Boost,Energy & Focus,Skin Glow,Hormonal Balance"
    },
    { "type": "header", "content": "Behaviour" },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed",
      "min": 10, "max": 60, "step": 5, "unit": "s",
      "default": 30,
      "info": "Lower value = faster scroll"
    },
    { "type": "header", "content": "Style" },
    { "type": "color",  "id": "bg_color",   "label": "Background colour", "default": "#2D4A30" },
    { "type": "color",  "id": "text_color", "label": "Text colour",       "default": "#ffffff" },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 11, "max": 22, "step": 1, "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "separator",
      "label": "Item separator",
      "options": [
        { "value": "leaf", "label": "🌿 Leaf" },
        { "value": "dot",  "label": "· Dot" },
        { "value": "dash", "label": "— Dash" }
      ],
      "default": "leaf"
    }
  ],
  "presets": [{ "name": "Marquee Strip" }]
}
{% endschema %}
