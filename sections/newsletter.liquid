{%- liquid
  assign bg_color     = section.settings.bg_color     | default: '#1A2B1E'
  assign text_color   = section.settings.text_color   | default: '#ffffff'
  assign privacy_text = section.settings.privacy_text | default: '🔒 No spam, ever. Unsubscribe anytime.'
  assign success_msg  = section.settings.success_msg  | default: '🌿 Welcome to the Solmara Circle!'
  assign placeholder  = section.settings.input_placeholder | default: 'your@email.com'
-%}

<style>
  .nwl-{{ section.id }} {
    padding-top:    {{ section.settings.pad_top }}px !important;
    padding-bottom: {{ section.settings.pad_bottom }}px !important;
    padding-left:   {{ section.settings.pad_left }}px !important;
    padding-right:  {{ section.settings.pad_right }}px !important;
  }
  @media (max-width: 768px) {
    .nwl-{{ section.id }} {
      padding-top:    {{ section.settings.mob_pad_top }}px !important;
      padding-bottom: {{ section.settings.mob_pad_bottom }}px !important;
      padding-left:   {{ section.settings.mob_pad_left }}px !important;
      padding-right:  {{ section.settings.mob_pad_right }}px !important;
    }
  }
</style>
<section class="newsletter nwl-{{ section.id }}"
  style="background-color: {{ bg_color }}; color: {{ text_color }};">
  <h2 class="nl-title" style="color: {{ text_color }}">
    {{ section.settings.heading | replace: 'Solmara Circle', '<em>Solmara Circle</em>' }}
  </h2>
  <p class="nl-sub" style="color: {{ text_color }}; opacity: 0.8">{{ section.settings.subheading }}</p>

  {%- form 'customer', id: 'newsletter-form' -%}
    <input type="hidden" name="contact[tags]" value="newsletter">
    <div class="nl-form">
      <input class="nl-input"
             type="email"
             name="contact[email]"
             id="nlEmail"
             placeholder="{{ placeholder }}"
             autocomplete="email"
             required
             aria-label="Email address">
      <button type="submit" class="nl-btn"
        style="background-color: {{ text_color }}; color: {{ bg_color }}">
        {{ section.settings.btn_label | default: 'Join Free' }}
      </button>
    </div>
    {%- if form.posted_successfully? -%}
      <p class="nl-success">{{ success_msg }}</p>
    {%- endif -%}
  {%- endform -%}

  {%- if privacy_text != blank -%}
    <p class="nl-privacy" style="color: {{ text_color }}; opacity: 0.6">{{ privacy_text }}</p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "div",
  "settings": [
    { "type": "header",   "content": "Content" },
    { "type": "text",     "id": "heading",          "label": "Heading",          "default": "Join the Solmara Circle" },
    { "type": "textarea", "id": "subheading",       "label": "Subheading" },
    { "type": "text",     "id": "btn_label",        "label": "Button text",      "default": "Join Free" },
    { "type": "text",     "id": "input_placeholder","label": "Input placeholder","default": "your@email.com" },
    { "type": "text",     "id": "privacy_text",     "label": "Privacy note",     "default": "🔒 No spam, ever. Unsubscribe anytime." },
    { "type": "text",     "id": "success_msg",      "label": "Success message",  "default": "🌿 Welcome to the Solmara Circle!" },
    { "type": "header",   "content": "Layout" },
        { "type": "header", "content": "── SPACING ──" },
    { "type": "paragraph", "content": "Desktop padding (applies above 768px)" },
    { "type": "range", "id": "pad_top",        "label": "Desktop top (px)",    "min": 0, "max": 200, "step": 4, "default": 60 },
    { "type": "range", "id": "pad_bottom",     "label": "Desktop bottom (px)", "min": 0, "max": 200, "step": 4, "default": 60 },
    { "type": "range", "id": "pad_left",       "label": "Desktop left (px)",   "min": 0, "max": 160, "step": 4, "default": 0 },
    { "type": "range", "id": "pad_right",      "label": "Desktop right (px)",  "min": 0, "max": 160, "step": 4, "default": 0 },
    { "type": "paragraph", "content": "Mobile padding (applies at ≤768px)" },
    { "type": "range", "id": "mob_pad_top",    "label": "Mobile top (px)",     "min": 0, "max": 120, "step": 4, "default": 40 },
    { "type": "range", "id": "mob_pad_bottom", "label": "Mobile bottom (px)",  "min": 0, "max": 120, "step": 4, "default": 40 },
    { "type": "range", "id": "mob_pad_left",   "label": "Mobile left (px)",    "min": 0, "max": 80,  "step": 4, "default": 0 },
    { "type": "range", "id": "mob_pad_right",  "label": "Mobile right (px)",   "min": 0, "max": 80,  "step": 4, "default": 0 },
    { "type": "header", "content": "Style" },
    { "type": "color",  "id": "bg_color",   "label": "Background colour", "default": "#1A2B1E" },
    { "type": "color",  "id": "text_color", "label": "Text & button colour", "default": "#ffffff" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
