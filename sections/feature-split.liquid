{%- liquid
  assign layout     = section.settings.layout     | default: 'image-left'
  assign section_bg = section.settings.section_bg | default: '#ffffff'
  assign visual_bg  = section.settings.visual_bg  | default: '#F0EBE3'
  if layout == 'image-right'
    assign visual_order = 2
    assign content_order = 1
  else
    assign visual_order = 1
    assign content_order = 2
  endif
-%}

{% comment %}─── FEATURE SPLIT ───{% endcomment %}
<style>
  .fsp-{{ section.id }} {
    padding-top:    {{ section.settings.pad_top }}px !important;
    padding-bottom: {{ section.settings.pad_bottom }}px !important;
    padding-left:   {{ section.settings.pad_left }}px !important;
    padding-right:  {{ section.settings.pad_right }}px !important;
  }
  @media (max-width: 768px) {
    .fsp-{{ section.id }} {
      padding-top:    {{ section.settings.mob_pad_top }}px !important;
      padding-bottom: {{ section.settings.mob_pad_bottom }}px !important;
      padding-left:   {{ section.settings.mob_pad_left }}px !important;
      padding-right:  {{ section.settings.mob_pad_right }}px !important;
    }
  }
</style>
<section class="feature-section fsp-{{ section.id }}"
  style="background-color: {{ section_bg }};">

  <div class="feature-visual" style="order: {{ visual_order }}; background-color: {{ visual_bg }}">
    {%- if section.settings.feature_image != blank -%}
      {{ section.settings.feature_image | image_url: width: 800 | image_tag:
          alt: section.settings.heading,
          loading: 'lazy',
          class: 'feature-img-photo' }}
    {%- else -%}
      <div class="feature-circles">
        <div class="fc-outer">
          <div class="fc-inner">
            <span class="fc-emoji">🌱</span>
            <span class="fc-text">Pure Source</span>
          </div>
        </div>
        <div class="fc-dot"></div>
        <div class="fc-dot2"></div>
      </div>
    {%- endif -%}
  </div>

  <div class="feature-content" style="order: {{ content_order }}">
    <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="feature-title">{{ section.settings.heading | replace: "nature's", "<em>nature's</em>" }}</h2>
    <p class="feature-body">{{ section.settings.body }}</p>

    <div class="feature-pillars">
      {%- for i in (1..3) -%}
        {%- assign icon_key  = 'pillar_' | append: i | append: '_icon' -%}
        {%- assign title_key = 'pillar_' | append: i | append: '_title' -%}
        {%- assign body_key  = 'pillar_' | append: i | append: '_body' -%}
        {%- if section.settings[title_key] != blank -%}
          <div class="pillar">
            <span class="pillar-icon">{{ section.settings[icon_key] }}</span>
            <div class="pillar-text">
              <h4>{{ section.settings[title_key] }}</h4>
              <p>{{ section.settings[body_key] }}</p>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.btn_label != blank -%}
      <a class="btn-fill" href="{{ section.settings.btn_url }}">{{ section.settings.btn_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Feature Split",
  "tag": "div",
  "settings": [
    { "type": "header",       "content": "Content" },
    { "type": "image_picker", "id": "feature_image",   "label": "Image (optional — replaces graphic)" },
    { "type": "text",         "id": "eyebrow",         "label": "Eyebrow",  "default": "✦ The Solmara Difference" },
    { "type": "text",         "id": "heading",          "label": "Heading",  "default": "Science meets nature's intelligence" },
    { "type": "textarea",     "id": "body",             "label": "Body text" },
    { "type": "header",       "content": "Pillar 1" },
    { "type": "text",         "id": "pillar_1_icon",    "label": "Icon",     "default": "🔬" },
    { "type": "text",         "id": "pillar_1_title",   "label": "Title",    "default": "Clinically Validated" },
    { "type": "textarea",     "id": "pillar_1_body",    "label": "Body" },
    { "type": "header",       "content": "Pillar 2" },
    { "type": "text",         "id": "pillar_2_icon",    "label": "Icon",     "default": "🌿" },
    { "type": "text",         "id": "pillar_2_title",   "label": "Title",    "default": "Certified Organic Sourcing" },
    { "type": "textarea",     "id": "pillar_2_body",    "label": "Body" },
    { "type": "header",       "content": "Pillar 3" },
    { "type": "text",         "id": "pillar_3_icon",    "label": "Icon",     "default": "♻️" },
    { "type": "text",         "id": "pillar_3_title",   "label": "Title",    "default": "Zero-Plastic Packaging" },
    { "type": "textarea",     "id": "pillar_3_body",    "label": "Body" },
    { "type": "header",       "content": "Button" },
    { "type": "text",         "id": "btn_label",        "label": "Button text", "default": "Our Standards →" },
    { "type": "url",          "id": "btn_url",          "label": "Button link" },
    { "type": "header",       "content": "Layout" },
    {
      "type": "select",
      "id": "layout",
      "label": "Image position",
      "options": [
        { "value": "image-left",  "label": "Image on left" },
        { "value": "image-right", "label": "Image on right" }
      ],
      "default": "image-left"
    },
        { "type": "header", "content": "── SPACING ──" },
    { "type": "paragraph", "content": "Desktop padding (applies above 768px)" },
    { "type": "range", "id": "pad_top",        "label": "Desktop top (px)",    "min": 0, "max": 200, "step": 4, "default": 60 },
    { "type": "range", "id": "pad_bottom",     "label": "Desktop bottom (px)", "min": 0, "max": 200, "step": 4, "default": 60 },
    { "type": "range", "id": "pad_left",       "label": "Desktop left (px)",   "min": 0, "max": 160, "step": 4, "default": 0 },
    { "type": "range", "id": "pad_right",      "label": "Desktop right (px)",  "min": 0, "max": 160, "step": 4, "default": 0 },
    { "type": "paragraph", "content": "Mobile padding (applies at ≤768px)" },
    { "type": "range", "id": "mob_pad_top",    "label": "Mobile top (px)",     "min": 0, "max": 120, "step": 4, "default": 40 },
    { "type": "range", "id": "mob_pad_bottom", "label": "Mobile bottom (px)",  "min": 0, "max": 120, "step": 4, "default": 40 },
    { "type": "range", "id": "mob_pad_left",   "label": "Mobile left (px)",    "min": 0, "max": 80,  "step": 4, "default": 0 },
    { "type": "range", "id": "mob_pad_right",  "label": "Mobile right (px)",   "min": 0, "max": 80,  "step": 4, "default": 0 },
    { "type": "header", "content": "Colours" },
    { "type": "color",  "id": "section_bg", "label": "Section background", "default": "#ffffff" },
    { "type": "color",  "id": "visual_bg",  "label": "Visual panel background", "default": "#F0EBE3" }
  ],
  "presets": [{ "name": "Feature Split" }]
}
{% endschema %}
