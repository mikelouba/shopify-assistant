{% comment %}── WELLNESS QUIZ PAGE ──{% endcomment %}
<style>
/* ─── Wellness Quiz: Self-contained, mobile-first ─────────────────────────────
   All selectors scoped under #quizPage for specificity over theme CSS.
   display:none uses !important so no theme rule can override visibility.
   ─────────────────────────────────────────────────────────────────────────── */

#quizPage *,
#quizPage *::before,
#quizPage *::after {
  box-sizing: border-box;
}

#quizPage {
  max-width: 680px;
  margin: 0 auto;
  padding: 28px 16px 64px;
  font-family: 'Jost', sans-serif;
  min-height: 60vh;
  color: #1a1a1a;
}

/* ── Progress bar ── */
#quizPage .quiz-progress-bar {
  width: 100%;
  height: 5px;
  background: #e8e4de;
  border-radius: 3px;
  margin-bottom: 28px;
  overflow: hidden;
}
#quizPage .quiz-progress-fill {
  height: 100%;
  width: 0%;
  background: #2D4A30;
  border-radius: 3px;
  transition: width 0.4s ease;
}

/* ── Screen visibility — THE CRITICAL FIX ── */
/* !important ensures no Shopify theme rule (however specific) can show inactive screens */
#quizPage .quiz-screen {
  display: none !important;
}
#quizPage .quiz-screen.active {
  display: block !important;
  animation: quizFadeIn 0.28s ease both;
}
@keyframes quizFadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── Shared eyebrow label ── */
#quizPage .section-eyebrow {
  display: inline-block;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: #2D4A30;
  margin-bottom: 16px;
}

/* ────────────────────────────────────────────────────────
   INTRO SCREEN
   ──────────────────────────────────────────────────────── */
#quizPage .quiz-intro-content {
  text-align: center;
  padding: 20px 0 28px;
}
#quizPage .quiz-intro-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 30px;
  font-weight: 500;
  line-height: 1.2;
  color: #1a1a1a;
  margin: 0 0 14px;
}
#quizPage .quiz-intro-title em {
  font-style: italic;
  color: #2D4A30;
}
#quizPage .quiz-intro-sub {
  font-size: 15px;
  color: #666;
  line-height: 1.65;
  margin: 0 0 22px;
}
#quizPage .quiz-intro-trust {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
  font-size: 13px;
  color: #555;
  margin-bottom: 28px;
}

/* Self-contained start button — does NOT rely on btn-fill */
#quizPage .quiz-start-btn {
  display: inline-block;
  padding: 16px 40px;
  background: #2D4A30;
  color: #fff !important;
  border: none;
  border-radius: 4px;
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
  -webkit-appearance: none;
  appearance: none;
  text-decoration: none;
}
#quizPage .quiz-start-btn:hover,
#quizPage .quiz-start-btn:focus {
  background: #1e3320;
  transform: translateY(-1px);
  outline: none;
  color: #fff !important;
}

/* ────────────────────────────────────────────────────────
   QUESTION CARD (wraps each question screen's content)
   ──────────────────────────────────────────────────────── */
#quizPage .quiz-q-card {
  background: #ffffff;
  border-radius: 16px;
  box-shadow: 0 2px 24px rgba(0, 0, 0, 0.08), 0 0 0 1px rgba(0, 0, 0, 0.04);
  padding: 24px 18px 22px;
}
#quizPage .quiz-step {
  display: inline-block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #2D4A30;
  margin-bottom: 10px;
}
#quizPage .quiz-q-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 22px;
  font-weight: 500;
  color: #1a1a1a;
  margin: 0 0 20px;
  line-height: 1.3;
}

/* ────────────────────────────────────────────────────────
   ANSWER OPTION BUTTONS
   ──────────────────────────────────────────────────────── */
#quizPage .quiz-options {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
/* Grid layout for icon-options (Q1, Q3, Q5) */
#quizPage .quiz-options--grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
/* List layout for text-only options (Q2, Q4, Q6) — explicit definition */
#quizPage .quiz-options--list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* Base pill button — completely self-contained, no theme classes needed */
#quizPage .quiz-opt {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 3px;
  padding: 14px 16px;
  background: #fafaf9;
  border: 1.5px solid #e0dbd3;
  border-radius: 10px;
  cursor: pointer;
  text-align: left;
  font-family: 'Jost', sans-serif;
  width: 100%;
  transition: border-color 0.18s, background 0.18s, box-shadow 0.18s, transform 0.12s;
  -webkit-appearance: none;
  appearance: none;
}
#quizPage .quiz-opt:hover,
#quizPage .quiz-opt:focus {
  border-color: #2D4A30;
  background: #f3f8f3;
  outline: none;
  transform: translateY(-1px);
}
#quizPage .quiz-opt.selected {
  border-color: #2D4A30;
  background: #eef5ee;
  box-shadow: 0 0 0 3px rgba(45, 74, 48, 0.14);
}

/* Wide (row) variant for list questions */
#quizPage .quiz-opt--wide {
  flex-direction: row;
  align-items: center;
  gap: 12px;
}

#quizPage .quiz-opt-icon {
  font-size: 22px;
  line-height: 1;
  margin-bottom: 4px;
  flex-shrink: 0;
  display: block;
}
#quizPage .quiz-opt--wide .quiz-opt-icon {
  margin-bottom: 0;
  font-size: 20px;
}
#quizPage .quiz-opt-label {
  font-size: 14px;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  line-height: 1.25;
}
#quizPage .quiz-opt-desc {
  font-size: 11px;
  color: #888;
  display: block;
  line-height: 1.4;
}
#quizPage .quiz-opt.selected .quiz-opt-label {
  color: #2D4A30;
}

/* ────────────────────────────────────────────────────────
   RESULTS SCREEN
   ──────────────────────────────────────────────────────── */
#quizPage .quiz-result-header {
  text-align: center;
  margin-bottom: 24px;
}
#quizPage .quiz-result-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 26px;
  font-weight: 500;
  color: #1a1a1a;
  margin: 10px 0 10px;
  line-height: 1.2;
}
#quizPage .quiz-result-title em {
  font-style: italic;
  color: #2D4A30;
}
#quizPage .quiz-result-sub {
  font-size: 14px;
  color: #666;
  line-height: 1.6;
  margin: 0;
}
#quizPage .quiz-result-card-wrap {
  margin-bottom: 24px;
}
#quizPage .quiz-result-card {
  border-radius: 16px;
  border: 1.5px solid #e0dbd3;
  padding: 28px 20px;
  text-align: center;
  box-shadow: 0 2px 20px rgba(0, 0, 0, 0.06);
}
#quizPage .quiz-result-emoji {
  font-size: 44px;
  margin-bottom: 10px;
  display: block;
}
#quizPage .quiz-result-card-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 20px;
  font-weight: 500;
  margin: 0 0 12px;
  line-height: 1.3;
}
#quizPage .quiz-result-card-desc {
  font-size: 14px;
  color: #555;
  line-height: 1.7;
  margin: 0 0 20px;
  text-align: left;
}
#quizPage .quiz-result-stats {
  display: flex;
  gap: 8px;
  justify-content: center;
  flex-wrap: wrap;
}
#quizPage .quiz-result-stat {
  background: rgba(255, 255, 255, 0.85);
  border: 1px solid rgba(0, 0, 0, 0.12);
  border-radius: 99px;
  padding: 5px 14px;
  font-size: 11px;
  font-weight: 600;
  color: #1a1a1a;
  white-space: nowrap;
}

/* Results CTAs — fully self-contained, no btn-fill / btn-outline */
#quizPage .quiz-result-actions {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 12px;
}
#quizPage .quiz-result-cta {
  display: block;
  padding: 16px 24px;
  background: #2D4A30;
  color: #fff !important;
  text-decoration: none !important;
  border-radius: 4px;
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  text-align: center;
  transition: background 0.2s, transform 0.15s;
  border: none;
}
#quizPage .quiz-result-cta:hover,
#quizPage .quiz-result-cta:focus {
  background: #1e3320;
  transform: translateY(-1px);
  color: #fff !important;
  outline: none;
}
#quizPage .quiz-restart-btn {
  display: block;
  width: 100%;
  padding: 14px 24px;
  background: transparent;
  border: 1.5px solid #2D4A30;
  color: #2D4A30;
  border-radius: 4px;
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
  text-align: center;
  -webkit-appearance: none;
  appearance: none;
}
#quizPage .quiz-restart-btn:hover,
#quizPage .quiz-restart-btn:focus {
  background: #2D4A30;
  color: #fff;
  outline: none;
}

/* ────────────────────────────────────────────────────────
   DESKTOP ENHANCEMENTS (min-width up — mobile is the base)
   ──────────────────────────────────────────────────────── */
@media (min-width: 601px) {
  #quizPage {
    padding: 48px 24px 80px;
  }
  #quizPage .quiz-intro-title {
    font-size: clamp(32px, 5vw, 48px);
  }
  #quizPage .quiz-q-card {
    padding: 36px 32px 32px;
  }
  #quizPage .quiz-q-title {
    font-size: clamp(22px, 3.5vw, 30px);
    margin-bottom: 28px;
  }
  #quizPage .quiz-opt {
    padding: 18px 20px;
  }
  #quizPage .quiz-opt-label {
    font-size: 15px;
  }
  #quizPage .quiz-opt-desc {
    font-size: 12px;
  }
  #quizPage .quiz-result-title {
    font-size: clamp(24px, 4vw, 36px);
  }
  #quizPage .quiz-result-card {
    padding: 36px 32px;
  }
  #quizPage .quiz-result-card-desc {
    font-size: 15px;
    text-align: center;
  }
  #quizPage .quiz-result-actions {
    align-items: center;
  }
  #quizPage .quiz-result-cta {
    display: inline-block;
    width: auto;
    padding: 16px 48px;
  }
  #quizPage .quiz-restart-btn {
    width: auto;
    padding: 14px 36px;
  }
}

/* ── Very small screens (iPhone SE 375px) ── */
@media (max-width: 375px) {
  #quizPage .quiz-options--grid {
    grid-template-columns: 1fr;
  }
  #quizPage .quiz-intro-title {
    font-size: 26px;
  }
}
</style>

<div class="quiz-page" id="quizPage">

  <!-- Progress bar -->
  <div class="quiz-progress-bar" aria-hidden="true">
    <div class="quiz-progress-fill" id="quizProgressFill"></div>
  </div>

  <!-- ── INTRO ── -->
  <div class="quiz-screen active" id="quizIntro">
    <div class="quiz-intro-content">
      <p class="section-eyebrow">✦ Personalized Wellness</p>
      <h1 class="quiz-intro-title">Discover your <em>perfect</em><br>wellness protocol</h1>
      <p class="quiz-intro-sub">Answer 6 quick questions and we'll recommend the exact Solmara formulas built for your body, lifestyle, and goals.</p>
      <div class="quiz-intro-trust">
        <span>🕐 60 seconds</span>
        <span>🎯 Personalized to you</span>
        <span>🌿 Completely free</span>
      </div>
      <button class="quiz-start-btn" onclick="quizStart()">
        Start the Quiz →
      </button>
    </div>
  </div>

  <!-- ── Q1: Primary goal ── -->
  <div class="quiz-screen" id="q1">
    <div class="quiz-q-card">
      <span class="quiz-step">1 of 6</span>
      <h2 class="quiz-q-title">What's your primary wellness goal right now?</h2>
      <div class="quiz-options quiz-options--grid">
        <button class="quiz-opt" onclick="quizNext('q1','q2',this,'goal','sleep')">
          <span class="quiz-opt-icon">😴</span>
          <span class="quiz-opt-label">Better Sleep</span>
          <span class="quiz-opt-desc">Fall asleep faster, stay asleep longer</span>
        </button>
        <button class="quiz-opt" onclick="quizNext('q1','q2',this,'goal','focus')">
          <span class="quiz-opt-icon">🧠</span>
          <span class="quiz-opt-label">Focus & Clarity</span>
          <span class="quiz-opt-desc">Sharpen thinking and memory</span>
        </button>
        <button class="quiz-opt" onclick="quizNext('q1','q2',this,'goal','stress')">
          <span class="quiz-opt-icon">🌿</span>
          <span class="quiz-opt-label">Stress Relief</span>
          <span class="quiz-opt-desc">Calm the nervous system naturally</span>
        </button>
        <button class="quiz-opt" onclick="quizNext('q1','q2',this,'goal','glow')">
          <span class="quiz-opt-icon">✨</span>
          <span class="quiz-opt-label">Skin Glow</span>
          <span class="quiz-opt-desc">Radiance from the inside out</span>
        </button>
        <button class="quiz-opt" onclick="quizNext('q1','q2',this,'goal','energy')">
          <span class="quiz-opt-icon">⚡</span>
          <span class="quiz-opt-label">Energy & Vitality</span>
          <span class="quiz-opt-desc">Sustain natural energy all day</span>
        </button>
      </div>
    </div>
  </div>

  <!-- ── Q2: How long ── -->
  <div class="quiz-screen" id="q2">
    <div class="quiz-q-card">
      <span class="quiz-step">2 of 6</span>
      <h2 class="quiz-q-title">How long have you been dealing with this?</h2>
      <div class="quiz-options quiz-options--list">
        <button class="quiz-opt quiz-opt--wide" onclick="quizNext('q2','q3',this,'duration','recent')">
          <span class="quiz-opt-label">Less than a month</span>
          <span class="quiz-opt-desc">Just starting to notice it</span>
        </button>
        <button class="quiz-opt quiz-opt--wide" onclick="quizNext('q2','q3',this,'duration','few_months')">
          <span class="quiz-opt-label">1 – 6 months</span>
          <span class="quiz-opt-desc">Building habits to address it</span>
        </button>
        <button class="quiz-opt quiz-opt--wide" onclick="quizNext('q2','q3',this,'duration','chronic')">
          <span class="quiz-opt-label">More than 6 months</span>
          <span class="quiz-opt-desc">Looking for a real, lasting solution</span>
        </button>
      </div>
    </div>
  </div>

  <!-- ── Q3: Lifestyle ── -->
  <div class="quiz-screen" id="q3">
    <div class="quiz-q-card">
      <span class="quiz-step">3 of 6</span>
      <h2 class="quiz-q-title">Which lifestyle description fits you best?</h2>
      <div class="quiz-options quiz-options--grid">
        <button class="quiz-opt" onclick="quizNext('q3','q4',this,'lifestyle','professional')">
          <span class="quiz-opt-icon">💼</span>
          <span class="quiz-opt-label">High-pressure career</span>
          <span class="quiz-opt-desc">Long hours, high stakes</span>
