{% comment %}── WELLNESS QUIZ PAGE ──{% endcomment %}
<style>
/* ─── Quiz Page: self-contained styles ─────────────────────────────────── */

.quiz-page {
  max-width: 760px;
  margin: 0 auto;
  padding: 48px 24px 80px;
  font-family: 'Jost', sans-serif;
  min-height: 60vh;
}

/* Progress bar */
.quiz-progress-bar {
  width: 100%;
  height: 4px;
  background: #e8e4de;
  border-radius: 2px;
  margin-bottom: 48px;
  overflow: hidden;
}
.quiz-progress-fill {
  height: 100%;
  width: 0%;
  background: #2D4A30;
  border-radius: 2px;
  transition: width 0.4s ease;
}

/* Screens — hidden by default, shown when .active */
.quiz-screen {
  display: none;
  animation: quizFadeIn 0.3s ease;
}
.quiz-screen.active {
  display: block;
}
@keyframes quizFadeIn {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── Intro ── */
.quiz-intro-content {
  text-align: center;
  max-width: 560px;
  margin: 0 auto;
  padding: 32px 0;
}
.section-eyebrow {
  display: inline-block;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: #2D4A30;
  margin-bottom: 20px;
}
.quiz-intro-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: clamp(32px, 5vw, 48px);
  font-weight: 500;
  line-height: 1.2;
  color: #1a1a1a;
  margin: 0 0 20px;
}
.quiz-intro-title em {
  font-style: italic;
  color: #2D4A30;
}
.quiz-intro-sub {
  font-size: 16px;
  color: #666;
  line-height: 1.6;
  margin: 0 0 28px;
}
.quiz-intro-trust {
  display: flex;
  gap: 24px;
  justify-content: center;
  flex-wrap: wrap;
  font-size: 13px;
  color: #555;
  margin-bottom: 36px;
}
.quiz-start-btn {
  display: inline-block;
  padding: 16px 40px;
  background: #2D4A30;
  color: #fff;
  border: none;
  border-radius: 3px;
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
}
.quiz-start-btn:hover {
  background: #1e3320;
  transform: translateY(-1px);
}

/* ── Question screens ── */
.quiz-q-inner {
  max-width: 640px;
  margin: 0 auto;
}
.quiz-step {
  display: inline-block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #2D4A30;
  margin-bottom: 16px;
}
.quiz-q-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: clamp(22px, 3.5vw, 30px);
  font-weight: 500;
  color: #1a1a1a;
  margin: 0 0 32px;
  line-height: 1.3;
}

/* Options containers */
.quiz-options {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.quiz-options--grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 12px;
}

/* Option buttons */
.quiz-opt {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 4px;
  padding: 18px 20px;
  background: #fff;
  border: 1.5px solid #e0dbd3;
  border-radius: 8px;
  cursor: pointer;
  text-align: left;
  transition: border-color 0.2s, background 0.2s, transform 0.15s;
  font-family: inherit;
}
.quiz-opt:hover {
  border-color: #2D4A30;
  background: #f5f9f5;
  transform: translateY(-1px);
}
.quiz-opt.selected {
  border-color: #2D4A30;
  background: #f0f6f0;
  box-shadow: 0 0 0 3px #2D4A3020;
}
.quiz-opt--wide {
  flex-direction: row;
  align-items: center;
  gap: 12px;
}
.quiz-opt-icon {
  font-size: 24px;
  line-height: 1;
  margin-bottom: 4px;
}
.quiz-opt--wide .quiz-opt-icon {
  margin-bottom: 0;
  font-size: 20px;
}
.quiz-opt-label {
  font-size: 15px;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
}
.quiz-opt-desc {
  font-size: 12px;
  color: #888;
  display: block;
  line-height: 1.4;
}

/* ── Results ── */
.quiz-result-inner {
  max-width: 640px;
  margin: 0 auto;
}
.quiz-result-header {
  text-align: center;
  margin-bottom: 36px;
}
.quiz-result-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: clamp(24px, 4vw, 36px);
  font-weight: 500;
  color: #1a1a1a;
  margin: 0 0 12px;
}
.quiz-result-title em {
  font-style: italic;
  color: #2D4A30;
}
.quiz-result-sub {
  font-size: 15px;
  color: #666;
  line-height: 1.6;
  margin: 0;
}
.quiz-result-card-wrap {
  margin-bottom: 36px;
}
.quiz-result-card {
  border-radius: 12px;
  border: 1.5px solid #e0dbd3;
  padding: 32px 28px;
  text-align: center;
}
.quiz-result-emoji {
  font-size: 48px;
  margin-bottom: 12px;
}
.quiz-result-card-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 22px;
  font-weight: 500;
  margin: 0 0 12px;
}
.quiz-result-card-desc {
  font-size: 15px;
  color: #555;
  line-height: 1.7;
  margin: 0 0 24px;
}
.quiz-result-stats {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
}
.quiz-result-stat {
  background: #fff;
  border: 1px solid #e0dbd3;
  border-radius: 99px;
  padding: 6px 16px;
  font-size: 12px;
  font-weight: 600;
  color: #1a1a1a;
  white-space: nowrap;
}
.quiz-result-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
}
.quiz-result-cta {
  display: inline-block;
  padding: 16px 40px;
  background: #2D4A30;
  color: #fff;
  text-decoration: none;
  border-radius: 3px;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  transition: background 0.2s, transform 0.15s;
}
.quiz-result-cta:hover {
  background: #1e3320;
  transform: translateY(-1px);
}
.quiz-restart-btn {
  background: transparent;
  border: 1.5px solid #2D4A30;
  color: #2D4A30;
  padding: 14px 36px;
  border-radius: 3px;
  font-family: 'Jost', sans-serif;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
}
.quiz-restart-btn:hover {
  background: #2D4A30;
  color: #fff;
}

/* Responsive */
@media (max-width: 600px) {
  .quiz-page { padding: 32px 16px 60px; }
  .quiz-options--grid { grid-template-columns: 1fr 1fr; }
  .quiz-intro-trust { gap: 14px; }
}
@media (max-width: 400px) {
  .quiz-options--grid { grid-template-columns: 1fr; }
}
</style>

<div class="quiz-page" id="quizPage">

  <!-- Progress bar -->
  <div class="quiz-progress-bar" aria-hidden="true">
    <div class="quiz-progress-fill" id="quizProgressFill"></div>
  </div>

  <!-- ── INTRO ── -->
  <div class="quiz-screen active" id="quizIntro">
    <div class="quiz-intro-content">
      <p class="section-eyebrow">✦ Personalized Wellness</p>
      <h1 class="quiz-intro-title">Discover your <em>perfect</em><br>wellness protocol</h1>
      <p class="quiz-intro-sub">Answer 6 quick questions and we'll recommend the exact Solmara formulas built for your body, lifestyle, and goals.</p>
      <div class="quiz-intro-trust">
        <span>🕐 60 seconds</span>
        <span>🎯 Personalized to you</span>
        <span>🌿 Completely free</span>
      </div>
      <button class="btn-fill quiz-start-btn" onclick="quizStart()">
        Start the Quiz →
      </button>
    </div>
  </div>

  <!-- ── Q1: Primary goal ── -->
  <div class="quiz-screen" id="q1">
    <div class="quiz-q-inner">
      <span class="quiz-step">1 of 6</span>
      <h2 class="quiz-q-title">What's your primary wellness goal right now?</h2>
      <div class="quiz-options quiz-options--grid">
        <button class="quiz-opt" onclick="quizNext('q1','q2',this,'goal','sleep')">
          <span class="quiz-opt-icon">😴</span>
          <span class="quiz-opt-label">Better Sleep</span>
          <span class="quiz-opt-desc">Fall asleep faster, stay asleep longer</span>
        </button>
        <button class="quiz-opt" onclick="quizNext('q1','q2',this,'goal','focus')">
          <span class="quiz-opt-icon">🧠</span>
          <span class="quiz-opt-label">Focus & Clarity</span>
          <span class="quiz-opt-desc">Sharpen thinking and memory</span>
        </button>
        <button class="quiz-opt" onclick="quizNext('q1','q2',this,'goal','stress')">
          <span class="quiz-opt-icon">🌿</span>
          <span class="quiz-opt-label">Stress Relief</span>
          <span class="quiz-opt-desc">Calm the nervous system naturally</span>
        </button>
        <button class="quiz-opt" onclick="quizNext('q1','q2',this,'goal','glow')">
          <span class="quiz-opt-icon">✨</span>
          <span class="quiz-opt-label">Skin Glow</span>
          <span class="quiz-opt-desc">Radiance from the inside out</span>
        </button>
        <button class="quiz-opt" onclick="quizNext('q1','q2',this,'goal','energy')">
          <span class="quiz-opt-icon">⚡</span>
          <span class="quiz-opt-label">Energy & Vitality</span>
          <span class="quiz-opt-desc">Sustain natural energy all day</span>
        </button>
      </div>
    </div>
  </div>

  <!-- ── Q2: How long ── -->
  <div class="quiz-screen" id="q2">
    <div class="quiz-q-inner">
      <span class="quiz-step">2 of 6</span>
      <h2 class="quiz-q-title">How long have you been dealing with this?</h2>
      <div class="quiz-options quiz-options--list">
        <button class="quiz-opt quiz-opt--wide" onclick="quizNext('q2','q3',this,'duration','recent')">
          <span class="quiz-opt-label">Less than a month</span>
          <span class="quiz-opt-desc">Just starting to notice it</span>
        </button>
        <button class="quiz-opt quiz-opt--wide" onclick="quizNext('q2','q3',this,'duration','few_months')">
          <span class="quiz-opt-label">1 – 6 months</span>
          <span class="quiz-opt-desc">Building habits to address it</span>
        </button>
        <button class="quiz-opt quiz-opt--wide" onclick="quizNext('q2','q3',this,'duration','chronic')">
          <span class="quiz-opt-label">More than 6 months</span>
          <span class="quiz-opt-desc">Looking for a real, lasting solution</span>
        </button>
      </div>
    </div>
  </div>

  <!-- ── Q3: Lifestyle ── -->
  <div class="quiz-screen" id="q3">
    <div class="quiz-q-inner">
      <span class="quiz-step">3 of 6</span>
      <h2 class="quiz-q-title">Which lifestyle description fits you best?</h2>
      <div class="quiz-options quiz-options--grid">
        <button class="quiz-opt" onclick="quizNext('q3','q4',this,'lifestyle','professional')">
          <span class="quiz-opt-icon">💼</span>
          <span class="quiz-opt-label">High-pressure career</span>
          <span class="quiz-opt-desc">Long hours, high stakes</span>
        </button>
        <button class="quiz-opt" onclick="quizNext('q3','q4',this,'lifestyle','parent')">
          <span class="quiz-opt-icon">👨‍👩‍👧</span>
          <span class="quiz-opt-label">Parent / caregiver</span>
          <span class="quiz-opt-desc">Always putting others first</span>
        </button>
        <button class="quiz-opt" onclick="quizNext('q3','q4',this,'lifestyle','active')">
          <span class="quiz-opt-icon">🏃</span>
          <span class="quiz-opt-label">Active & athletic</span>
          <span class="quiz-opt-desc">Fitness is part of daily life</span>
        </button>
        <button class="quiz-opt" onclick="quizNext('q3','q4',this,'lifestyle','creative')">
          <span class="quiz-opt-icon">🎨</span>
          <span class="quiz-opt-label">Creative or student</span>
          <span class="quiz-opt-desc">Need mental stamina and flow</span>
        </button>
      </div>
    </div>
  </div>

  <!-- ── Q4: Experience ── -->
  <div class="quiz-screen" id="q4">
    <div class="quiz-q-inner">
      <span class="quiz-step">4 of 6</span>
      <h2 class="quiz-q-title">Have you tried supplements before?</h2>
      <div class="quiz-options quiz-options--list">
        <button class="quiz-opt quiz-opt--wide" onclick="quizNext('q4','q5',this,'exp','new')">
          <span class="quiz-opt-label">New to supplements</span>
          <span class="quiz-opt-desc">Starting from scratch — I need guidance</span>
        </button>
        <button class="quiz-opt quiz-opt--wide" onclick="quizNext('q4','q5',this,'exp','tried')">
          <span class="quiz-opt-label">Tried a few things</span>
          <span class="quiz-opt-desc">Had mixed or inconsistent results</span>
        </button>
        <button class="quiz-opt quiz-opt--wide" onclick="quizNext('q4','q5',this,'exp','experienced')">
          <span class="quiz-opt-label">Regular supplement user</span>
          <span class="quiz-opt-desc">I know what I'm looking for</span>
        </button>
      </div>
    </div>
  </div>

  <!-- ── Q5: Form preference ── -->
  <div class="quiz-screen" id="q5">
    <div class="quiz-q-inner">
      <span class="quiz-step">5 of 6</span>
      <h2 class="quiz-q-title">How do you prefer to take supplements?</h2>
      <div class="quiz-options quiz-options--grid">
        <button class="quiz-opt" onclick="quizNext('q5','q6',this,'form','capsule')">
          <span class="quiz-opt-icon">💊</span>
          <span class="quiz-opt-label">Capsules</span>
          <span class="quiz-opt-desc">Quick and easy</span>
        </button>
        <button class="quiz-opt" onclick="quizNext('q5','q6',this,'form','powder')">
          <span class="quiz-opt-icon">🥤</span>
          <span class="quiz-opt-label">Powder / drink</span>
          <span class="quiz-opt-desc">Blend into smoothie or water</span>
        </button>
        <button class="quiz-opt" onclick="quizNext('q5','q6',this,'form','tincture')">
          <span class="quiz-opt-icon">💧</span>
          <span class="quiz-opt-label">Liquid / tincture</span>
          <span class="quiz-opt-desc">Fast absorption under the tongue</span>
        </button>
        <button class="quiz-opt" onclick="quizNext('q5','q6',this,'form','any')">
          <span class="quiz-opt-icon">🌿</span>
          <span class="quiz-opt-label">No preference</span>
          <span class="quiz-opt-desc">Whatever works best</span>
        </button>
      </div>
    </div>
  </div>

  <!-- ── Q6: Budget ── -->
  <div class="quiz-screen" id="q6">
    <div class="quiz-q-inner">
      <span class="quiz-step">6 of 6</span>
      <h2 class="quiz-q-title">What's your monthly wellness budget?</h2>
      <div class="quiz-options quiz-options--list">
        <button class="quiz-opt quiz-opt--wide" onclick="quizNext('q6','quizResult',this,'budget','starter')">
          <span class="quiz-opt-label">Under $40 / month</span>
          <span class="quiz-opt-desc">Start with one powerful core product</span>
        </button>
        <button class="quiz-opt quiz-opt--wide" onclick="quizNext('q6','quizResult',this,'budget','mid')">
          <span class="quiz-opt-label">$40 – $80 / month</span>
          <span class="quiz-opt-desc">Build a targeted 2-product stack</span>
        </button>
        <button class="quiz-opt quiz-opt--wide" onclick="quizNext('q6','quizResult',this,'budget','full')">
          <span class="quiz-opt-label">$80+ / month</span>
          <span class="quiz-opt-desc">Full protocol for maximum results</span>
        </button>
      </div>
    </div>
  </div>

  <!-- ── RESULTS ── -->
  <div class="quiz-screen" id="quizResult">
    <div class="quiz-result-inner">
      <div class="quiz-result-header">
        <p class="section-eyebrow">✦ Your Wellness Protocol</p>
        <h2 class="quiz-result-title">Your personalized <em>plan</em> is ready</h2>
        <p class="quiz-result-sub">Based on your answers, here's what we'd recommend to get the best results.</p>
      </div>

      <div class="quiz-result-card-wrap" id="quizResultCard">
        <!-- Populated by JS -->
      </div>

      <div class="quiz-result-actions">
        <a class="btn-fill quiz-result-cta" id="quizResultCta" href="{{ routes.all_products_collection_url }}">
          Shop My Protocol →
        </a>
        <button class="btn-outline quiz-restart-btn" onclick="quizRestart()">
          Retake the quiz
        </button>
      </div>
    </div>
  </div>

</div>

<script>
(function () {
  'use strict';

  const answers = {};
  const TOTAL_Q = 6;
  let currentQ  = 0;

  const GOAL_MAP = {
    sleep: {
      emoji: '😴',
      title: 'Better Sleep Protocol',
      desc:  'Your answers point to a nervous system that needs help unwinding. We recommend our Ashwagandha Complex paired with the Sleep Ritual blend — non-habit-forming, deeply restorative sleep from night one.',
      stats: ['+68% sleep quality', '−23 min sleep onset', '0 habit-forming compounds'],
      url:   '/pages/goal-sleep',
      accent: '#7B9CC4',
      bg:    '#E8EDF5'
    },
    focus: {
      emoji: '🧠',
      title: 'Focus & Cognitive Protocol',
      desc:  "Your profile points to a need for sustained mental clarity and neuroprotection. We recommend our Lion's Mane Complex with Bacopa Monnieri — the stack that sharpens focus without the caffeine crash.",
      stats: ['89% better focus', '+42% NGF production', 'Zero stimulants'],
      url:   '/pages/goal-focus',
      accent: '#C49B6C',
      bg:    '#F5EDE0'
    },
    stress: {
      emoji: '🌿',
      title: 'Calm & Stress Relief Protocol',
      desc:  'Your cortisol levels need support. We recommend the KSM-66 Ashwagandha + Rhodiola Rosea stack — the gold standard for regulating the HPA-axis and restoring your baseline calm.',
      stats: ['−28% cortisol', '91% feel calmer in 2 weeks', '0 pharmaceutical compounds'],
      url:   '/pages/goal-stress',
      accent: '#7EAA82',
      bg:    '#E8F0E8'
    },
    glow: {
      emoji: '✨',
      title: 'Skin Glow Protocol',
      desc:  'Your skin needs internal nourishment. We recommend our Marine Collagen Peptides + Antioxidant Glow blend — a clinical dose of collagen paired with skin-brightening botanicals.',
      stats: ['+87% visible improvement', '5g clinical collagen dose', '−24% fine lines at 12 wks'],
      url:   '/pages/goal-glow',
      accent: '#C47B8C',
      bg:    '#F5E8ED'
    },
    energy: {
      emoji: '⚡',
      title: 'Energy & Vitality Protocol',
      desc:  'Your body is running on reserves. We recommend our Cordyceps + Adaptogen Vitality blend — 8 hours of clean, sustained energy without stimulants, crashes, or dependency.',
      stats: ['+84% vitality at 6 weeks', '92% eliminated slumps', '0 synthetic stimulants'],
      url:   '/pages/goal-energy',
      accent: '#C4A027',
      bg:    '#F5EDD8'
    }
  };

  window.quizStart = function () {
    currentQ = 1;
    updateProgress();
    showScreen('q1');
  };

  window.quizNext = function (fromId, toId, btn, key, value) {
    answers[key] = value;

    // Mark selection
    btn.closest('.quiz-options').querySelectorAll('.quiz-opt').forEach(function (b) {
      b.classList.remove('selected');
    });
    btn.classList.add('selected');

    if (toId === 'quizResult') {
      buildResult();
    } else {
      currentQ++;
      updateProgress();
    }

    setTimeout(function () { showScreen(toId); }, 240);
  };

  window.quizRestart = function () {
    Object.keys(answers).forEach(function (k) { delete answers[k]; });
    currentQ = 0;
    document.querySelectorAll('.quiz-opt').forEach(function (b) { b.classList.remove('selected'); });
    var fill = document.getElementById('quizProgressFill');
    if (fill) fill.style.width = '0%';
    showScreen('quizIntro');
  };

  function showScreen(id) {
    document.querySelectorAll('.quiz-screen').forEach(function (s) { s.classList.remove('active'); });
    var el = document.getElementById(id);
    if (el) {
      el.classList.add('active');
      el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  function updateProgress() {
    var pct  = Math.round(((currentQ - 1) / TOTAL_Q) * 100);
    var fill = document.getElementById('quizProgressFill');
    if (fill) fill.style.width = pct + '%';
  }

  function buildResult() {
    var fill = document.getElementById('quizProgressFill');
    if (fill) fill.style.width = '100%';

    var goal = answers.goal || 'sleep';
    var g    = GOAL_MAP[goal];

    var statsHtml = g.stats.map(function (s) {
      return '<span class="quiz-result-stat">' + s + '</span>';
    }).join('');

    var wrap = document.getElementById('quizResultCard');
    if (wrap) {
      wrap.innerHTML =
        '<div class="quiz-result-card" style="background:' + g.bg + ';border-color:' + g.accent + '33">' +
          '<div class="quiz-result-emoji">' + g.emoji + '</div>' +
          '<h3 class="quiz-result-card-title" style="color:' + g.accent + '">' + g.title + '</h3>' +
          '<p class="quiz-result-card-desc">' + g.desc + '</p>' +
          '<div class="quiz-result-stats">' + statsHtml + '</div>' +
        '</div>';
    }

    var cta = document.getElementById('quizResultCta');
    if (cta) cta.href = g.url;
  }
}());
</script>

{% schema %}
{ "name": "Wellness Quiz", "tag": "div", "settings": [], "presets": [{"name":"Wellness Quiz"}] }
{% endschema %}
