{%- if paginate.pages > 1 -%}
<nav class="pagination" aria-label="Pagination">
  {%- if paginate.previous -%}
    <a href="{{ paginate.previous.url }}" class="pagination-btn prev" aria-label="Previous page">← Prev</a>
  {%- else -%}
    <span class="pagination-btn prev disabled" aria-disabled="true">← Prev</span>
  {%- endif -%}

  <div class="pagination-pages">
    {%- for part in paginate.parts -%}
      {%- if part.is_link -%}
        <a href="{{ part.url }}" class="pagination-num">{{ part.title }}</a>
      {%- elsif part.title == paginate.current_page -%}
        <span class="pagination-num active" aria-current="page">{{ part.title }}</span>
      {%- else -%}
        <span class="pagination-ellipsis">…</span>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if paginate.next -%}
    <a href="{{ paginate.next.url }}" class="pagination-btn next" aria-label="Next page">Next →</a>
  {%- else -%}
    <span class="pagination-btn next disabled" aria-disabled="true">Next →</span>
  {%- endif -%}
</nav>
{%- endif -%}
